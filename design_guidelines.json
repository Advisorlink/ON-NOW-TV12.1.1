{
  "theme": "DARK",
  "archetype": "5 (Jewel & Luxury) + Cyberpunk Tech",
  "app_context": "Android TV native player overlay for Vesper / ON NOW TV V2",
  "colors": {
    "background": {
      "base": "#020610",
      "surface": "#0A1322",
      "surface_light": "#0D121C"
    },
    "primary": "#5DC8FF",
    "accent": "#7CF1F1",
    "text": {
      "main": "#FFFFFF",
      "muted": "rgba(255, 255, 255, 0.6)",
      "disabled": "rgba(255, 255, 255, 0.4)"
    },
    "glass": {
      "background": "rgba(10, 19, 34, 0.6)",
      "border": "rgba(255, 255, 255, 0.08)"
    }
  },
  "typography": {
    "headings": {
      "font_family": "Outfit, sans-serif",
      "weights": [300, 500, 700, 900],
      "sizes": {
        "h1": "48px (text-5xl)",
        "h2": "32px (text-3xl)",
        "h3": "24px (text-xl)"
      }
    },
    "metadata": {
      "font_family": "JetBrains Mono, monospace",
      "weights": [400, 700],
      "sizes": {
        "eyebrow": "12px",
        "chip": "14px",
        "hud": "13px"
      }
    },
    "body": {
      "font_family": "Outfit, sans-serif",
      "weights": [400, 500],
      "sizes": {
        "base": "16px",
        "large": "20px (text-xl)"
      }
    }
  },
  "layout": {
    "tv_resolution": "1920x1080",
    "left_fade_overlay": {
      "width": "45%",
      "gradient": "linear-gradient(to right, #020610 0%, rgba(2, 6, 16, 0.9) 60%, transparent 100%)"
    },
    "bottom_dock": {
      "height": "400px",
      "gradient": "linear-gradient(to top, rgba(2, 6, 16, 0.9) 0%, rgba(2, 6, 16, 0.5) 50%, transparent 100%)"
    },
    "spacing": {
      "screen_padding": "64px (px-16)",
      "element_gap": "24px (gap-6)",
      "chip_padding": "4px 10px"
    }
  },
  "components": {
    "buttons": {
      "default_size": "64x64px",
      "primary_size": "88x88px",
      "border_radius": "50%",
      "idle_state": {
        "bg": "rgba(255, 255, 255, 0.05)",
        "color": "rgba(255, 255, 255, 0.8)",
        "border": "2px solid transparent"
      },
      "focus_state": {
        "bg": "#5DC8FF",
        "color": "#020610",
        "border": "2px solid rgba(255, 255, 255, 0.5)",
        "transform": "scale(1.1)",
        "box_shadow": "0 0 24px rgba(93, 200, 255, 0.4)",
        "transition": "all 0.22s cubic-bezier(0.4, 0, 0.2, 1)"
      }
    },
    "scrubber": {
      "track_height": "8px",
      "focus_track_height": "14px",
      "fill_color": "#5DC8FF",
      "thumb_size": "24x24px",
      "thumb_color": "#FFFFFF",
      "thumb_shadow": "0 0 12px rgba(93, 200, 255, 0.8)"
    },
    "glass_card": {
      "bg": "rgba(10, 19, 34, 0.85)",
      "backdrop_filter": "blur(40px)",
      "border": "1px solid rgba(93, 200, 255, 0.2)",
      "border_radius": "24px",
      "box_shadow": "0 24px 64px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.1)"
    },
    "chips": {
      "cyan": {
        "bg": "rgba(93, 200, 255, 0.15)",
        "border": "1px solid rgba(93, 200, 255, 0.4)",
        "color": "#5DC8FF"
      },
      "outline": {
        "border": "1px solid rgba(255, 255, 255, 0.2)",
        "color": "rgba(255, 255, 255, 0.8)"
      }
    }
  },
  "motion": {
    "fade_in": "220ms ease-out",
    "scale_up": "220ms cubic-bezier(0.4, 0, 0.2, 1)",
    "focus_ring": "150ms ease-in"
  },
  "testing": {
    "attributes": "All interactive elements must include data-testid. Examples: audio-btn, subtitle-btn, play-pause-btn, stream-picker-btn"
  },
  "media": {
    "image_urls": {
      "movie_background": {
        "url": "https://images.unsplash.com/photo-1682687220063-4742bd7fd538?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjY2NjV8MHwxfHNlYXJjaHwxfHxjaW5lbWF0aWMlMjBzY2klMjBmaSUyMG1vdmllJTIwbGFuZHNjYXBlfGVufDB8fHx8MTc3OTM1MjQ3MXww&ixlib=rb-4.1.0&q=85",
        "description": "Cinematic sci-fi desert background for overlay mockups"
      }
    }
  },
  "instructions_to_main_agent": "Use Jetpack Compose TV for the implementation. Ensure exact D-pad focus scaling as specified in the components section. Adhere to the cyan/navy color palette strictly and retain monospace for data/metadata chips."
}