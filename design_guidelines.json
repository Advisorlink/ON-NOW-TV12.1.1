    "focus_state": {
      "description": "Massive, unmistakable D-pad focus state. The scale must enlarge the item, surrounded by a glowing copper ring.",
      "transform": "scale(1.08)",
      "box_shadow": "0 0 0 4px #050505, 0 0 0 8px #E58A59, 0 20px 40px rgba(229, 138, 89, 0.3)",
      "z_index": 50,
      "transition": "all 0.3s cubic-bezier(0.25, 1, 0.5, 1)",
      "outline": "none"
    }
  },
  "motion_specs": {
    "focus": "Spring-based snap. 300ms duration, cubic-bezier(0.25, 1, 0.5, 1)",
    "hero_ken_burns": "Very slow scale 1.0 to 1.05 over 20 seconds, linear",
    "shelf_scroll": "Snap to start, smooth scrolling behavior enabled via CSS scroll-snap-type: x mandatory",
    "page_transition": "Fade in 400ms ease-out"
  },
  "layout": {
    "overscan_margin": "5%",
    "structure": {
