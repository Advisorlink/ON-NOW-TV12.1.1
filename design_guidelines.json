  "aesthetic_direction": {
    "rationale": "Vesper evokes the evening star, dusk, and after-dark cinema. A 'Vespertine Observatory' aesthetic focuses on deep night blues/blacks, high-contrast copper/dusk-gold accents, and a cinematic/noir archive feel. Textures like subtle film grain and atmospheric lighting replace flat gradients. It’s designed specifically for 10-foot TV viewing, leveraging massive typography and generous spacing.",
    "anti_patterns": [
      "No Inter, Roboto, or Space Grotesk",
      "No purple/violet gradients",
      "No generic centered grids",
      "No small tap targets (must be built for D-pad focus)"
    ]
  },
  "color_tokens": {
    "background": {
      "L0": "#050505",
      "L1": "#0A0D14",
      "L2": "#121620",
      "overlay": "rgba(5, 5, 5, 0.7)"
