# v2.10.22 — Android build cache (regenerated on every gradle run)
# Untracking ~1,000 files / ~32 MB.  These should never have been
# committed; safe to delete from working copy too — Gradle rebuilds.
# ----------------------------------------------------------------
**/.gradle/
**/build/
android/**/local.properties
android/**/.idea/
*.iml

