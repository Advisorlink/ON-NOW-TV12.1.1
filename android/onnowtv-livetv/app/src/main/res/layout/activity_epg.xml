<?xml version="1.0" encoding="utf-8"?>
<!--
    V2 Live TV — Vesper-style layout.

      • Hero (fixed top, 240dp): TMDB backdrop + LIVE TV eyebrow,
        big channel name, NOW programme info, cyan progress bar,
        UP NEXT line.  Top-right corner: Favourite / Refresh /
        Sign-out icon cluster.
      • Body (3 columns):
          – Categories list (left, 240dp wide)
          – Channels list   (middle, 380dp wide) — pill cards with
                              logo + ch# + name + NOW + progress
          – Guide list      (right, fills remainder) — grouped by
                              TODAY / TOMORROW
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/epg_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/livetv_bg"
    android:focusable="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ────────── HERO ────────── -->
        <FrameLayout
            android:id="@+id/hero"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ImageView
                android:id="@+id/hero_backdrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@null" />

            <!-- Left-to-right gradient overlay for legibility. -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/hero_gradient" />

            <!-- Bottom fade so hero blends into body. -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_gravity="bottom"
                android:background="@drawable/hero_bottom_fade" />

            <!-- Top-right utility icon cluster. -->
            <LinearLayout
                android:id="@+id/hero_icon_cluster"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="28dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/clock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="14dp"
                    android:textColor="@color/livetv_fg_bright"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:text="" />

                <ImageButton
                    android:id="@+id/btn_favourite"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/hero_icon_btn_bg"
                    android:src="@drawable/ic_star"
                    android:padding="10dp"
                    android:focusable="true"
                    android:contentDescription="Favourite" />

                <ImageButton
                    android:id="@+id/btn_refresh"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/hero_icon_btn_bg"
                    android:src="@drawable/ic_refresh"
                    android:padding="10dp"
                    android:focusable="true"
                    android:contentDescription="Refresh" />

                <ImageButton
                    android:id="@+id/btn_logout"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/hero_icon_btn_bg"
                    android:src="@drawable/ic_exit"
                    android:padding="10dp"
                    android:focusable="true"
                    android:contentDescription="Sign out" />
            </LinearLayout>

            <!-- Hero text content -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="start|bottom"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="36dp"
                android:layout_marginEnd="320dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/hero_eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_accent"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.32"
                    android:text="LIVE TV" />

                <TextView
                    android:id="@+id/hero_channel_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/livetv_fg"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.025"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="Live TV" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/hero_now_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="@color/livetv_accent"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.24"
                        android:text="NOW" />

                    <TextView
                        android:id="@+id/hero_now_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:textColor="@color/livetv_fg_bright"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:text="" />
                </LinearLayout>

                <TextView
                    android:id="@+id/hero_synopsis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/livetv_fg_dim"
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:text="" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="10dp"
                    android:background="#1AFFFFFF">

                    <View
                        android:id="@+id/hero_progress"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@color/livetv_accent" />
                </FrameLayout>

                <TextView
                    android:id="@+id/hero_up_next"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_fg_dimmer"
                    android:textSize="10sp"
                    android:letterSpacing="0.20"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="" />
            </LinearLayout>
        </FrameLayout>

        <!-- ────────── BODY (3 columns) ────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <!-- Left: categories -->
            <LinearLayout
                android:layout_width="220dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="10dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_fg_dimmer"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.24"
                    android:text="CATEGORIES" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/categories_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:descendantFocusability="afterDescendants"
                    android:focusable="true"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />
            </LinearLayout>

            <!-- Middle: channels -->
            <LinearLayout
                android:layout_width="360dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">

                <TextView
                    android:id="@+id/channels_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="10dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_fg_dimmer"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.24"
                    android:text="CHANNELS" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/channels_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:descendantFocusability="afterDescendants"
                    android:focusable="true"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />
            </LinearLayout>

            <!-- Right: guide -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="10dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_fg_dimmer"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.24"
                    android:text="GUIDE" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/guide_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:descendantFocusability="afterDescendants"
                    android:focusable="true"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
