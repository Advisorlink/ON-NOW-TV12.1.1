<?xml version="1.0" encoding="utf-8"?>
<!--
    V2 Live TV — final Vesper-reference layout (v2.8.117).

    Structure:
      [ ICON RAIL 64dp ] [ MAIN ]

    MAIN = vertical:
      HERO (380dp): backdrop full-width + V2 monogram top-left in cyan glow,
                    LIVE TV · CH 236 cyan monospace, MASSIVE channel name (72sp),
                    NOW · 03:00 PM · prog title + 2-line synopsis,
                    cyan progress bar, UP NEXT footer.
                    Top-right: clock + Favourite / Refresh / Sign-out 40dp pills.

      BODY 3 columns:
        L (220dp): CHANNEL GROUPS list (Favourites, Recently Watched, then categories).
        M (440dp): CHANNELS list (channel# + logo + name + NOW pill + prog title + progress).
        R (fills): GUIDE — TODAY · SAT 16 MAY 03:34 PM header, then GUIDE · CHANNEL banner,
                   then list of programmes with monospace time + OK TO REMIND label.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/livetv_bg">

    <!-- ───────── LEFT ICON RAIL ───────── -->
    <LinearLayout
        android:layout_width="64dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:background="#0E1422">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="V2"
            android:textColor="@color/livetv_accent"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.04"
            android:shadowColor="#665DC8FF"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="14" />

        <Space android:layout_width="0dp" android:layout_height="42dp" />

        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:layout_marginBottom="32dp" android:src="@drawable/ic_nav_home"
            android:contentDescription="@null" />

        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:src="@drawable/ic_nav_tv"
            android:contentDescription="@null" />
    </LinearLayout>

    <!-- ───────── MAIN ───────── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- HERO -->
        <FrameLayout
            android:id="@+id/hero"
            android:layout_width="match_parent"
            android:layout_height="380dp">

            <ImageView
                android:id="@+id/hero_backdrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@null" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/hero_gradient" />

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_gravity="bottom"
                android:background="@drawable/hero_bottom_fade" />

            <!-- Top-right icon cluster + clock -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/clock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="14dp"
                    android:textColor="@color/livetv_fg_bright"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:text="" />

                <ImageButton android:id="@+id/btn_favourite"
                    android:layout_width="40dp" android:layout_height="40dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/hero_icon_btn_bg"
                    android:src="@drawable/ic_star"
                    android:padding="10dp" android:focusable="true"
                    android:contentDescription="Favourite" />

                <ImageButton android:id="@+id/btn_refresh"
                    android:layout_width="40dp" android:layout_height="40dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/hero_icon_btn_bg"
                    android:src="@drawable/ic_refresh"
                    android:padding="10dp" android:focusable="true"
                    android:contentDescription="Refresh" />

                <ImageButton android:id="@+id/btn_logout"
                    android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/hero_icon_btn_bg"
                    android:src="@drawable/ic_exit"
                    android:padding="10dp" android:focusable="true"
                    android:contentDescription="Sign out" />
            </LinearLayout>

            <!-- Hero text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="start|bottom"
                android:layout_marginStart="36dp"
                android:layout_marginEnd="420dp"
                android:layout_marginBottom="28dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/hero_eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_accent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.30"
                    android:text="LIVE TV" />

                <TextView
                    android:id="@+id/hero_channel_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/livetv_fg"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.03"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="LIVE TV" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="@color/livetv_accent"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.24"
                        android:text="NOW" />

                    <TextView
                        android:id="@+id/hero_now_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="monospace"
                        android:textColor="@color/livetv_accent"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.18"
                        android:text="" />

                    <TextView
                        android:id="@+id/hero_now_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:textColor="@color/livetv_fg_bright"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:text="" />
                </LinearLayout>

                <TextView
                    android:id="@+id/hero_synopsis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/livetv_fg_dim"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:text="" />

                <FrameLayout
                    android:layout_width="420dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="14dp"
                    android:background="#1AFFFFFF">

                    <View
                        android:id="@+id/hero_progress"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@color/livetv_accent" />
                </FrameLayout>

                <TextView
                    android:id="@+id/hero_up_next"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_fg_dimmer"
                    android:textSize="10sp"
                    android:letterSpacing="0.22"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="" />
            </LinearLayout>
        </FrameLayout>

        <!-- BODY 3 columns -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:paddingStart="36dp"
            android:paddingEnd="36dp"
            android:paddingTop="6dp"
            android:paddingBottom="20dp">

            <!-- Categories -->
            <LinearLayout
                android:layout_width="220dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_marginEnd="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="10dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_fg_dimmer"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.24"
                    android:text="CHANNEL GROUPS" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/categories_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:descendantFocusability="afterDescendants"
                    android:focusable="true"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />
            </LinearLayout>

            <!-- Channels -->
            <LinearLayout
                android:layout_width="440dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_marginEnd="20dp">

                <TextView
                    android:id="@+id/channels_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="10dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_fg_dimmer"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.24"
                    android:text="CHANNELS" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/channels_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:descendantFocusability="afterDescendants"
                    android:focusable="true"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />
            </LinearLayout>

            <!-- Guide -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/guide_today"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:textColor="@color/livetv_accent"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.24"
                        android:text="TODAY" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/guide_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:descendantFocusability="afterDescendants"
                    android:focusable="true"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
