<?xml version="1.0" encoding="utf-8"?>
<!--
    V2 Live TV EPG (matches Vesper reference screenshot).

    Layout:
      [ ICON RAIL 64dp ] [ MAIN ]

    Icon rail (top-to-bottom):  V2 wordmark · Home · Search · Refresh · List
                                                                              [bottom]
                                Sign-out

    MAIN = vertical:
      HERO (380dp): backdrop + LIVE TV·CH 236 eyebrow + BIG channel name +
                    NOW pill · prog title + synopsis + cyan progress bar +
                    UP NEXT.  Top-right: clock + Favourite / Refresh / Sign-out.

      BODY 3 columns:
        L  (220dp): "CHANNEL GROUPS" + Favourites / Recently Watched pills +
                    region groups with counts.
        M  (440dp): "Search channels & guide…" bar + channel count chip +
                    channel pill list.
        R  (fills): "TODAY · {DATE}" header + "GUIDE · {CHANNEL}" sub-header +
                    list of programmes with bell + OK TO REMIND.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/livetv_bg">

    <!-- ───────── LEFT ICON RAIL ───────── -->
    <LinearLayout
        android:layout_width="64dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:background="#0E1422">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="V2"
            android:textColor="@color/livetv_accent_red"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.04"
            android:shadowColor="#80FF2535"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="14" />

        <Space android:layout_width="0dp" android:layout_height="38dp" />

        <ImageButton android:id="@+id/rail_home"
            android:layout_width="44dp" android:layout_height="44dp"
            android:layout_marginBottom="14dp"
            android:padding="10dp"
            android:src="@drawable/ic_nav_home"
            android:background="@drawable/rail_icon_bg"
            android:focusable="true"
            android:contentDescription="Home" />

        <ImageButton android:id="@+id/rail_search"
            android:layout_width="44dp" android:layout_height="44dp"
            android:layout_marginBottom="14dp"
            android:padding="10dp"
            android:src="@drawable/ic_nav_search"
            android:background="@drawable/rail_icon_bg"
            android:focusable="true"
            android:contentDescription="Search" />

        <ImageButton android:id="@+id/rail_refresh"
            android:layout_width="44dp" android:layout_height="44dp"
            android:layout_marginBottom="14dp"
            android:padding="10dp"
            android:src="@drawable/ic_refresh"
            android:background="@drawable/rail_icon_bg"
            android:focusable="true"
            android:contentDescription="Refresh" />

        <ImageButton android:id="@+id/rail_list"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_nav_list"
            android:background="@drawable/rail_icon_bg"
            android:focusable="true"
            android:contentDescription="List" />

        <Space android:layout_width="0dp" android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton android:id="@+id/rail_signout"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_nav_signout"
            android:background="@drawable/rail_icon_bg"
            android:focusable="true"
            android:contentDescription="Sign out" />
    </LinearLayout>

    <!-- ───────── MAIN ───────── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- HERO (shorter — gives the body 9-row capacity) -->
        <FrameLayout
            android:id="@+id/hero"
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <ImageView
                android:id="@+id/hero_backdrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:adjustViewBounds="false"
                android:contentDescription="@null" />

            <!-- Solid floor under the backdrop so 4:3 / pillarbox
                 logos don't render with letterbox bars. -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/livetv_bg"
                android:alpha="0.20" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/hero_gradient" />

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_gravity="bottom"
                android:background="@drawable/hero_bottom_fade" />

            <!-- Top-right icon cluster + clock -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/clock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="14dp"
                    android:textColor="@color/livetv_fg_bright"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:text="" />

                <ImageButton android:id="@+id/btn_favourite"
                    android:layout_width="40dp" android:layout_height="40dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/hero_icon_btn_bg"
                    android:src="@drawable/ic_star"
                    android:padding="10dp" android:focusable="true"
                    android:contentDescription="Favourite" />

                <ImageButton android:id="@+id/btn_refresh"
                    android:layout_width="40dp" android:layout_height="40dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/hero_icon_btn_bg"
                    android:src="@drawable/ic_refresh"
                    android:padding="10dp" android:focusable="true"
                    android:contentDescription="Refresh" />

                <ImageButton android:id="@+id/btn_logout"
                    android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/hero_icon_btn_bg"
                    android:src="@drawable/ic_exit"
                    android:padding="10dp" android:focusable="true"
                    android:contentDescription="Sign out" />
            </LinearLayout>

            <!-- Hero text — top-left anchored.  Now shows NOW info
                 and a stacked UP NEXT card below. -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="start|top"
                android:layout_marginStart="36dp"
                android:layout_marginEnd="380dp"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/hero_eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_accent"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.30"
                    android:text="LIVE TV" />

                <TextView
                    android:id="@+id/hero_channel_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/livetv_fg"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.03"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="LIVE TV" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="@color/livetv_accent"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.24"
                        android:text="NOW" />

                    <TextView
                        android:id="@+id/hero_now_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="monospace"
                        android:textColor="@color/livetv_accent"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.18"
                        android:text="" />

                    <TextView
                        android:id="@+id/hero_now_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:textColor="@color/livetv_fg_bright"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:text="" />
                </LinearLayout>

                <TextView
                    android:id="@+id/hero_synopsis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/livetv_fg_dim"
                    android:textSize="11sp"
                    android:lineSpacingExtra="1dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:text="" />

                <FrameLayout
                    android:layout_width="380dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="6dp"
                    android:background="#1AFFFFFF">

                    <View
                        android:id="@+id/hero_progress"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@color/livetv_accent" />
                </FrameLayout>

                <!-- Single-line UP NEXT footer (matches reference exactly:
                     monospace dim text below the progress bar). -->
                <TextView
                    android:id="@+id/hero_up_next"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_fg_dimmer"
                    android:textSize="11sp"
                    android:letterSpacing="0.22"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="" />

                <!-- Hidden views (legacy id references kept for safety) -->
                <LinearLayout
                    android:id="@+id/hero_up_next_card"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    android:orientation="vertical">
                    <TextView android:id="@+id/up_next_1_time" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    <TextView android:id="@+id/up_next_1_title" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    <TextView android:id="@+id/up_next_2_time" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    <TextView android:id="@+id/up_next_2_title" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    <TextView android:id="@+id/up_next_3_time" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    <TextView android:id="@+id/up_next_3_title" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>
                <TextView
                    android:id="@+id/hero_up_next_time"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/hero_up_next_title"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />
            </LinearLayout>
        </FrameLayout>

        <!-- BODY 3 columns -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:paddingStart="36dp"
            android:paddingEnd="36dp"
            android:paddingTop="10dp"
            android:paddingBottom="20dp">

            <!-- L: Channel groups -->
            <LinearLayout
                android:layout_width="220dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_marginEnd="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="10dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_fg_dimmer"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.24"
                    android:text="CHANNEL GROUPS" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/categories_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:descendantFocusability="afterDescendants"
                    android:focusable="false"
                    android:nestedScrollingEnabled="true"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />
            </LinearLayout>

            <!-- M: Channels -->
            <LinearLayout
                android:layout_width="660dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_marginEnd="20dp">

                <!-- Search bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/search_bar_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="10dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_search_small"
                        android:contentDescription="@null" />

                    <EditText
                        android:id="@+id/search_input"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:textColor="@color/livetv_fg"
                        android:textColorHint="@color/livetv_fg_dimmer"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:hint="Search channels &amp; guide…"
                        android:singleLine="true"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />

                    <TextView
                        android:id="@+id/channel_count_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:background="@drawable/channel_count_chip_bg"
                        android:fontFamily="monospace"
                        android:textColor="@color/livetv_accent"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.20"
                        android:text="0 CHANNELS" />
                </LinearLayout>

                <Space android:layout_width="0dp" android:layout_height="10dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/channels_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:descendantFocusability="afterDescendants"
                    android:focusable="true"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />
            </LinearLayout>

            <!-- R: Guide -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Date + clock row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="6dp">

                    <TextView
                        android:id="@+id/guide_today"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:textColor="@color/livetv_accent"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.24"
                        android:text="TODAY" />

                    <TextView
                        android:id="@+id/guide_clock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="@color/livetv_fg_dim"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.18"
                        android:text="" />
                </LinearLayout>

                <!-- GUIDE · channel sub-header -->
                <TextView
                    android:id="@+id/guide_channel_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="2dp"
                    android:paddingBottom="10dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_fg_dimmer"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.24"
                    android:text="GUIDE" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/guide_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:descendantFocusability="afterDescendants"
                    android:focusable="true"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
