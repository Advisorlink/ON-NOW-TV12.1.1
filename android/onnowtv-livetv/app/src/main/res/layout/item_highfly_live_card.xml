<?xml version="1.0" encoding="utf-8"?>
<!-- v2.10.61 — LIVE NOW card.  16:9 landscape, 340×191 dp (down
     from 380×214) so 5 cards fit cleanly on a 1080p TV with the
     edge of the 6th peeking in as a scroll hint.  Per-sport
     gradient is applied as the ImageView background by the
     adapter so the card never looks dead when the addon ships
     no poster URL. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="340dp"
    android:layout_height="191dp"
    android:layout_marginEnd="16dp"
    android:focusable="true"
    android:clickable="true"
    android:background="@drawable/highfly_card_bg"
    android:foreground="@drawable/highfly_card_focus_fg"
    android:clipToOutline="true">

    <ImageView
        android:id="@+id/live_card_poster"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/highfly_card_gradient" />

    <!-- Top-left LIVE pill -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="9dp"
        android:paddingVertical="4dp"
        android:background="@drawable/highfly_live_pill_bg">

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/highfly_live_dot"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LIVE"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.18" />
    </LinearLayout>

    <!-- Bottom: title + meta line -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="14dp"
        android:paddingTop="20dp">

        <TextView
            android:id="@+id/live_card_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F5F8FF"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.01"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/live_card_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#C2CEE3"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:layout_marginTop="4dp"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>
</FrameLayout>
