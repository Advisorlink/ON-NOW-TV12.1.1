<?xml version="1.0" encoding="utf-8"?>
<!-- 16:9 collection tile.  AI-generated cover fills the card edge-to-edge,
     a dark gradient overlay keeps the channel-count + name legible. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="180dp"
    android:layout_marginEnd="18dp"
    android:background="@drawable/library_tile_bg"
    android:focusable="true"
    android:clickable="true">

    <ImageView
        android:id="@+id/tile_cover"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/library_tile_overlay" />

    <!-- Bottom strip — collection name + channel count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/tile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"
            android:maxLines="1"
            android:ellipsize="end"
            android:shadowColor="#000000"
            android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3"
            android:text="Sports" />

        <TextView
            android:id="@+id/tile_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="monospace"
            android:textColor="#9CB0D8"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.22"
            android:text="42 CHANNELS" />
    </LinearLayout>

    <!-- "Generating…" badge shown while the Nano Banana call is
         in flight after a "Regenerate cover" long-press. -->
    <TextView
        android:id="@+id/tile_busy_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="10dp"
        android:background="@drawable/preview_live_badge_bg"
        android:fontFamily="monospace"
        android:paddingHorizontal="9dp"
        android:paddingVertical="3dp"
        android:text="GENERATING…"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.18"
        android:visibility="gone" />
</FrameLayout>
