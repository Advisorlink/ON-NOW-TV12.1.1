<?xml version="1.0" encoding="utf-8"?>
<!--
    "Add to Library" dialog — Vesper-style glass card with a single
    cinematic CTA.  Three visual states baked into one layout via
    visibility flips by the activity:

      • Idle     — header + body + 2 buttons (Add+Generate / Cancel)
      • Busy     — header + body + indeterminate progress + elapsed
                   timer + 1 button (Cancel)
      • Result   — header + body + success message + 1 button (Done)

    This replaces the legacy 1980s-era AlertDialog.Builder modal.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/library_dialog_bg"
    android:padding="36dp"
    android:elevation="24dp">

    <!-- ───────────────────── Header ───────────────────── -->
    <TextView
        android:id="@+id/dlg_eyebrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:textColor="@color/livetv_accent"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.32"
        android:text="MY LIBRARY" />

    <TextView
        android:id="@+id/dlg_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="sans-serif-black"
        android:textColor="@color/livetv_fg"
        android:textSize="30sp"
        android:textStyle="bold"
        android:letterSpacing="-0.025"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="Add Sky Sports to library?" />

    <TextView
        android:id="@+id/dlg_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="sans-serif"
        android:textColor="@color/livetv_fg_dim"
        android:textSize="14sp"
        android:lineSpacingExtra="3dp"
        android:text="We'll generate a realistic 16:9 promotional banner that looks like a proper broadcaster cover — usually 10–20 seconds." />

    <!-- ─────────────── Progress block (hidden by default) ─────────────── -->
    <LinearLayout
        android:id="@+id/dlg_progress_block"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Fake progress strip — animated client-side toward ~95 %
             then completes when the network call resolves. -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="@drawable/library_progress_track">

            <View
                android:id="@+id/dlg_progress_fill"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/library_progress_fill" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dlg_progress_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:textColor="@color/livetv_fg_bright"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.22"
                android:text="GENERATING COVER…" />

            <TextView
                android:id="@+id/dlg_progress_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/livetv_accent"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.22"
                android:text="0s" />
        </LinearLayout>
    </LinearLayout>

    <!-- ───────────────────── Buttons ───────────────────── -->
    <LinearLayout
        android:id="@+id/dlg_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/dlg_btn_secondary"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:minWidth="120dp"
            android:paddingHorizontal="24dp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/livetv_fg_dim"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:letterSpacing="0.0"
            android:background="@drawable/library_btn_secondary_bg"
            android:focusable="true"
            android:text="Cancel" />

        <Button
            android:id="@+id/dlg_btn_primary"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            android:minWidth="200dp"
            android:paddingHorizontal="28dp"
            android:fontFamily="sans-serif-black"
            android:textColor="#06080F"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:letterSpacing="-0.005"
            android:background="@drawable/library_btn_primary_bg"
            android:focusable="true"
            android:text="Add + Generate" />
    </LinearLayout>
</LinearLayout>
