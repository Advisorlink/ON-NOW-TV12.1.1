<?xml version="1.0" encoding="utf-8"?>
<!-- v2.10.59 — Highfly Sports Guide redesigned to match the user's
     mockup.  Sections from top to bottom:
       1. HERO (50% of screen height): featured live event,
          blurred poster background, centered "TEAM A vs TEAM B"
          title, big LIVE pill, "Watch Live" CTA.
       2. LIVE NOW: horizontal row of 16:9 cards with the actual
          live events from the addon (max 8).
       3. SPORT FILTER: horizontal scrollable row of circular
          icon chips — "All Sports" + every sport from the
          addon's manifest.  Selected chip glows cyan.
       4. COMING UP TODAY: horizontal row of upcoming-today
          cards with kickoff time in AEDT.
     Nothing on this surface reveals the addon URL / source. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#04060B">

    <!-- Ambient deep-navy gradient backdrop. -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/highfly_bg_gradient" />

    <ScrollView
        android:id="@+id/highfly_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true"
        android:descendantFocusability="afterDescendants">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- =================== HERO =================== -->
            <FrameLayout
                android:id="@+id/hero_root"
                android:layout_width="match_parent"
                android:layout_height="540dp"
                android:focusable="true"
                android:clickable="true">

                <!-- Full-bleed blurred poster -->
                <ImageView
                    android:id="@+id/hero_poster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@null" />

                <!-- Dark gradient veil — fades to navy at bottom -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/highfly_hero_veil" />

                <!-- Side-cone gradients so player photos at the
                     edges of the poster have headroom but the
                     centre title is fully legible. -->
                <View
                    android:layout_width="200dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:background="@drawable/highfly_hero_side_left" />

                <View
                    android:layout_width="200dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:background="@drawable/highfly_hero_side_right" />

                <!-- Centered: LIVE pill + league + "Team A vs Team B" + CTA -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <LinearLayout
                        android:id="@+id/hero_live_pill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="7dp"
                        android:background="@drawable/highfly_live_pill_bg"
                        android:visibility="gone">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/highfly_live_dot"
                            android:layout_marginEnd="9dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LIVE"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.18" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/hero_league"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:textColor="#F5F8FF"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif"
                        android:letterSpacing="0.04"
                        android:singleLine="true"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/hero_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:textColor="#FFFFFF"
                        android:textSize="68sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="-0.02"
                        android:gravity="center"
                        android:maxLines="2"
                        android:ellipsize="end"
                        tools:text="Man City vs PSG" />

                    <TextView
                        android:id="@+id/hero_meta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="#C2CEE3"
                        android:textSize="15sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.1" />

                    <!-- Watch Live CTA -->
                    <LinearLayout
                        android:id="@+id/hero_watch_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="64dp"
                        android:layout_marginTop="34dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="34dp"
                        android:background="@drawable/highfly_cta_bg"
                        android:focusable="true"
                        android:clickable="true">

                        <!-- Triangle "play" mark -->
                        <View
                            android:layout_width="14dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="14dp"
                            android:background="@drawable/highfly_play_triangle" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Watch Live"
                            android:textColor="#04060B"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="-0.01" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Top-right corner: AEDT clock -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="32dp"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/highfly_clock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#F5F8FF"
                        android:textSize="22sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.04" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SYDNEY · AEDT"
                        android:textColor="#7A8AB2"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.22" />
                </LinearLayout>

                <!-- Top-left corner: eyebrow -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="32dp"
                    android:text="LIVE SPORTS"
                    android:textColor="#5DC8FF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.32" />
            </FrameLayout>

            <!-- =================== LIVE NOW =================== -->
            <TextView
                android:id="@+id/section_live_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:paddingHorizontal="48dp"
                android:text="Live Now"
                android:textColor="#F5F8FF"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.01" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/section_live_cards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:paddingHorizontal="48dp"
                android:paddingVertical="14dp"
                android:clipToPadding="false"
                android:scrollbars="none" />

            <!-- =================== SPORT FILTER =================== -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/section_sport_filter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:paddingHorizontal="48dp"
                android:paddingVertical="14dp"
                android:clipToPadding="false"
                android:scrollbars="none" />

            <!-- =================== COMING UP TODAY =================== -->
            <TextView
                android:id="@+id/section_today_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="48dp"
                android:text="Coming Up Today"
                android:textColor="#F5F8FF"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.01" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/section_today_cards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:paddingHorizontal="48dp"
                android:paddingVertical="14dp"
                android:paddingBottom="48dp"
                android:clipToPadding="false"
                android:scrollbars="none" />

        </LinearLayout>
    </ScrollView>

    <!-- Loader -->
    <TextView
        android:id="@+id/highfly_loader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Loading the sports guide…"
        android:textColor="#7A8AB2"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.2"
        android:visibility="gone" />

</FrameLayout>
