<?xml version="1.0" encoding="utf-8"?>
<!-- ON NOW V2 LIVE TV — first-launch login screen (v2.9.5).
     Brand-styled dark navy card centred on the EPG splash colour. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/livetv_bg">

    <LinearLayout
        android:layout_width="460dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/action_sheet_card_bg"
        android:clipToOutline="true">

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#5DC8FF" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="26dp"
            android:paddingTop="24dp"
            android:text="ON NOW V2 LIVE TV"
            android:textColor="#7A8AB2"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.2"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="26dp"
            android:paddingTop="6dp"
            android:paddingBottom="22dp"
            android:text="Sign in to your account"
            android:textColor="#F5F8FF"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium" />

        <EditText
            android:id="@+id/login_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="22dp"
            android:layout_marginBottom="12dp"
            android:padding="14dp"
            android:background="@drawable/input_field_bg"
            android:textColor="#F5F8FF"
            android:textColorHint="#5F6A85"
            android:textSize="16sp"
            android:hint="Username"
            android:singleLine="true"
            android:inputType="text"
            android:imeOptions="actionNext" />

        <EditText
            android:id="@+id/login_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="22dp"
            android:layout_marginBottom="18dp"
            android:padding="14dp"
            android:background="@drawable/input_field_bg"
            android:textColor="#F5F8FF"
            android:textColorHint="#5F6A85"
            android:textSize="16sp"
            android:hint="Password"
            android:singleLine="true"
            android:inputType="textPassword"
            android:imeOptions="actionDone" />

        <TextView
            android:id="@+id/login_submit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="22dp"
            android:gravity="center"
            android:text="SIGN IN"
            android:textColor="#5DC8FF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.18"
            android:background="@drawable/action_sheet_row_bg"
            android:focusable="true"
            android:clickable="true" />

        <TextView
            android:id="@+id/login_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="26dp"
            android:paddingTop="14dp"
            android:paddingBottom="20dp"
            android:textColor="#FF8AA9"
            android:textSize="13sp"
            android:fontFamily="sans-serif"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
