<?xml version="1.0" encoding="utf-8"?>
<!--
    Full-screen ExoPlayer.

    Layers (top → bottom):
      1) PlayerView (the video)
      2) Channel info overlay — top-left card with channel logo +
         LCN + name + NOW programme + progress bar + UP NEXT.
         Auto-fades 4 seconds after every tune-in / channel change.
      3) Number-tune indicator — top-right pill showing the
         typed digit stream ("→ 21…") while the user types a
         channel number on the remote.
      4) Status / error text (centred).
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:keepScreenOn="true">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:resize_mode="fit"
        app:use_controller="false"
        app:show_buffering="never" />

    <!-- ─────────── Orbital buffering loader (centred) ─────────── -->
    <!-- Shown only while ExoPlayer is in STATE_BUFFERING (managed
         by PlayerActivity.onPlaybackStateChanged).  Hardware-
         accelerated custom View — no bitmap allocations per frame. -->
    <tv.onnowtv.livetv.ui.OrbitalLoaderView
        android:id="@+id/buffer_loader"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- ─────────── Channel info overlay (top-left) ─────────── -->
    <!-- HIDDEN per user request — kept in the tree so existing
         findViewById refs in PlayerActivity still resolve.  All
         code paths that previously animated this in are now no-ops
         (see PlayerActivity.showInfoCard). -->
    <LinearLayout
        android:id="@+id/info_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="28dp"
        android:layout_marginTop="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone"
        android:elevation="6dp">

        <ImageView
            android:id="@+id/info_logo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerInside"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/info_lcn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_accent"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.18"
                    android:text="" />

                <TextView
                    android:id="@+id/info_channel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/livetv_fg"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:background="@drawable/now_pill_red"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_bg"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.18"
                    android:text="NOW" />

                <TextView
                    android:id="@+id/info_now_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:maxWidth="420dp"
                    android:textColor="@color/livetv_fg_bright"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="" />
            </LinearLayout>

            <!-- Skinny cyan progress bar — current programme. -->
            <FrameLayout
                android:layout_width="380dp"
                android:layout_height="2dp"
                android:layout_marginTop="6dp"
                android:background="#1AFFFFFF">

                <View
                    android:id="@+id/info_progress"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@color/livetv_accent" />
            </FrameLayout>

            <TextView
                android:id="@+id/info_up_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:textColor="@color/livetv_fg_dimmer"
                android:textSize="9sp"
                android:letterSpacing="0.18"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="" />
        </LinearLayout>
    </LinearLayout>

    <!-- ─────────── Number-tune pill (top-right) ─────────── -->
    <TextView
        android:id="@+id/tune_pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="36dp"
        android:layout_marginEnd="36dp"
        android:background="@drawable/player_overlay_bg"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:fontFamily="monospace"
        android:textColor="@color/livetv_accent"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.16"
        android:visibility="gone"
        android:text="" />

    <!-- ─────────── Status / errors (centred) ─────────── -->
    <TextView
        android:id="@+id/player_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="@color/livetv_fg"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        android:text="" />

    <!-- ─────────── Channel + programme info card (bottom-left) ───────────
         v2.9.1: re-enabled per user request.  Shows channel logo +
         LCN + name + current programme title + description.  Auto-
         fades 5 seconds after every tune-in OR when the controls
         bar opens (which already carries the same metadata). -->
    <LinearLayout
        android:id="@+id/player_info_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="36dp"
        android:layout_marginBottom="128dp"
        android:maxWidth="640dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/player_card_bg"
        android:paddingStart="16dp"
        android:paddingEnd="22dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:visibility="gone"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/player_info_logo"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerInside"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/player_info_channel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F5F8FF"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="" />

            <TextView
                android:id="@+id/player_info_programme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#5DC8FF"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="" />

            <TextView
                android:id="@+id/player_info_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#9CB0D8"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="" />
        </LinearLayout>
    </LinearLayout>

    <!-- ─────────── Modern control bar (v2.9.9) ───────────
         A floating glass pill anchored above the bottom edge.
         Layout:
            [« 10s]  [⏵/⏸  HERO]  [10s »]  ·  [CC]  [⤢]  [ⓘ]
         All buttons are circular ImageButtons with the neon-blue
         focus glow drawable.  Center Play/Pause is larger (the
         hero CTA).  The right cluster (CC / aspect / info) sits
         after a subtle divider so it reads as a secondary group.

         Auto-shows on remote interaction; auto-hides after 5 s
         (managed by PlayerActivity). -->
    <LinearLayout
        android:id="@+id/player_controls_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp"
        android:background="@drawable/player_modern_bar_bg"
        android:visibility="gone"
        android:elevation="12dp">

        <!-- Rewind 10s -->
        <ImageButton
            android:id="@+id/btn_player_rewind"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="10dp"
            android:padding="14dp"
            android:src="@drawable/ic_player_rewind"
            android:background="@drawable/player_modern_btn_bg"
            android:scaleType="centerInside"
            android:focusable="true"
            android:clickable="true"
            android:contentDescription="Rewind 10 seconds" />

        <!-- Play / Pause — HERO -->
        <ImageButton
            android:id="@+id/btn_player_playpause"
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:layout_marginHorizontal="6dp"
            android:padding="20dp"
            android:src="@drawable/ic_player_pause"
            android:background="@drawable/player_modern_playpause_bg"
            android:scaleType="centerInside"
            android:focusable="true"
            android:clickable="true"
            android:contentDescription="Play / Pause" />

        <!-- Forward 10s -->
        <ImageButton
            android:id="@+id/btn_player_forward"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="10dp"
            android:padding="14dp"
            android:src="@drawable/ic_player_forward"
            android:background="@drawable/player_modern_btn_bg"
            android:scaleType="centerInside"
            android:focusable="true"
            android:clickable="true"
            android:contentDescription="Forward 10 seconds" />

        <!-- Soft divider between transport & options -->
        <View
            android:layout_width="1dp"
            android:layout_height="36dp"
            android:layout_marginHorizontal="18dp"
            android:background="#26344E" />

        <!-- Subtitles / Closed Captions -->
        <ImageButton
            android:id="@+id/btn_player_subtitles"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginHorizontal="6dp"
            android:padding="13dp"
            android:src="@drawable/ic_player_cc"
            android:background="@drawable/player_modern_btn_bg"
            android:scaleType="centerInside"
            android:focusable="true"
            android:clickable="true"
            android:contentDescription="Subtitles" />

        <!-- Aspect ratio toggle -->
        <ImageButton
            android:id="@+id/btn_player_aspect"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginHorizontal="6dp"
            android:padding="13dp"
            android:src="@drawable/ic_player_aspect"
            android:background="@drawable/player_modern_btn_bg"
            android:scaleType="centerInside"
            android:focusable="true"
            android:clickable="true"
            android:contentDescription="Aspect ratio" />

        <!-- Programme info -->
        <ImageButton
            android:id="@+id/btn_player_info"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="6dp"
            android:padding="13dp"
            android:src="@drawable/ic_player_info"
            android:background="@drawable/player_modern_btn_bg"
            android:scaleType="centerInside"
            android:focusable="true"
            android:clickable="true"
            android:contentDescription="Programme info" />
    </LinearLayout>
</FrameLayout>
