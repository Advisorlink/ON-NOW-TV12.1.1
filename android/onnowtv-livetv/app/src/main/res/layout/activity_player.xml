<?xml version="1.0" encoding="utf-8"?>
<!--
    v2.10 — Full-screen ExoPlayer with the design-spec overlay.

    Layers (back → front):
      1) PlayerView (the actual video)
      2) Buffering loader (centered, neon blue)
      3) Tune-in pill (top-right — typed channel digits)
      4) Top-right CLOCK / DATE column
      5) Bottom info panel + control bar — auto-fades 5 s after
         the last remote input
      6) Status / error text (centered)

    Designed for 1920×1080 (16:9).  All paddings/sizes are dp and
    scale cleanly on other TV sizes.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:keepScreenOn="true">

    <!-- ─────────── (1) Video surface ─────────── -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:resize_mode="fit"
        app:use_controller="false"
        app:show_buffering="never" />

    <!-- ─────────── (2) Orbital buffering loader (centred) ─────────── -->
    <tv.onnowtv.livetv.ui.OrbitalLoaderView
        android:id="@+id/buffer_loader"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- ─────────── (3) Tune-in pill (top-right) ─────────── -->
    <!-- Shown when the user types channel digits on the remote.
         Auto-clears 1.5 s after the last digit. -->
    <TextView
        android:id="@+id/tune_pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="36dp"
        android:layout_marginEnd="36dp"
        android:paddingHorizontal="18dp"
        android:paddingVertical="10dp"
        android:background="@drawable/tune_pill_bg"
        android:textColor="#5DC8FF"
        android:textSize="22sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.12"
        android:visibility="gone"
        tools:ignore="HardcodedText"
        tools:text="→ 21…" />

    <!-- ─────────── (4) Top-right CLOCK / DATE ─────────── -->
    <!-- Shows whenever the info overlay is visible.  Time = bold
         white display number with a small subscript "PM"; date =
         small cyan caption underneath. -->
    <LinearLayout
        android:id="@+id/player_clock_block"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="34dp"
        android:layout_marginEnd="48dp"
        android:orientation="vertical"
        android:gravity="end"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:baselineAligned="false">

            <TextView
                android:id="@+id/player_clock_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="44sp"
                android:fontFamily="sans-serif-light"
                android:includeFontPadding="false"
                android:letterSpacing="-0.02"
                tools:text="9:15" />

            <TextView
                android:id="@+id/player_clock_ampm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="6dp"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                tools:text="PM" />
        </LinearLayout>

        <TextView
            android:id="@+id/player_clock_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-4dp"
            android:textColor="#5DC8FF"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.04"
            tools:text="Sat, May 25" />
    </LinearLayout>

    <!-- ─────────── (5) Bottom info panel + controls ─────────── -->
    <LinearLayout
        android:id="@+id/player_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/player_overlay_scrim_bg"
        android:visibility="gone">

        <!-- ── Info row: 3-column layout ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="48dp"
            android:paddingTop="26dp"
            android:paddingBottom="18dp">

            <!-- Cyan accent stripe -->
            <View
                android:layout_width="3dp"
                android:layout_height="118dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/player_left_accent_bar" />

            <!-- LEFT column: channel number + logo + LIVE pill -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginEnd="32dp">

                <TextView
                    android:id="@+id/player_info_lcn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="44sp"
                    android:fontFamily="sans-serif-black"
                    android:includeFontPadding="false"
                    android:letterSpacing="-0.02"
                    tools:text="007" />

                <ImageView
                    android:id="@+id/player_info_logo"
                    android:layout_width="120dp"
                    android:layout_height="44dp"
                    android:layout_marginTop="4dp"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"
                    android:contentDescription="@null"
                    tools:src="@android:drawable/ic_menu_gallery" />

                <TextView
                    android:id="@+id/player_info_live_red"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:paddingHorizontal="9dp"
                    android:paddingVertical="2dp"
                    android:background="@drawable/player_live_red_pill_bg"
                    android:text="● LIVE"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.18"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <!-- CENTER column: NOW programme info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Title row: programme name + cyan LIVE chip -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/player_info_programme"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-medium"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.01"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:maxWidth="540dp"
                        tools:text="SoundWave Live" />

                    <TextView
                        android:id="@+id/player_info_live_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:paddingHorizontal="7dp"
                        android:paddingVertical="2dp"
                        android:background="@drawable/player_live_cyan_chip_bg"
                        android:text="LIVE"
                        android:textColor="#04101F"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.18"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <!-- Cyan accent line: segment / sub-title -->
                <TextView
                    android:id="@+id/player_info_segment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textColor="#5DC8FF"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif"
                    android:singleLine="true"
                    android:ellipsize="end"
                    tools:text="Rock the Night" />

                <!-- Description -->
                <TextView
                    android:id="@+id/player_info_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#B0BACC"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    tools:text="The best live performances and music videos from today's top rock artists." />

                <!-- Time range -->
                <TextView
                    android:id="@+id/player_info_time_range"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="8:00 PM – 10:00 PM" />

                <!-- Progress + LIVE chip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ProgressBar
                        android:id="@+id/player_info_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="3dp"
                        android:layout_weight="1"
                        android:progressDrawable="@drawable/player_progress_bar"
                        android:max="1000"
                        android:progress="540" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="LIVE"
                        android:textColor="#5DC8FF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.22"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
            </LinearLayout>

            <!-- Soft divider between NOW and NEXT -->
            <View
                android:layout_width="1dp"
                android:layout_height="92dp"
                android:layout_marginHorizontal="22dp"
                android:layout_gravity="center_vertical"
                android:background="#26344E" />

            <!-- RIGHT column: NEXT programme -->
            <LinearLayout
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NEXT"
                    android:textColor="#5DC8FF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.32"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/player_info_next_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-medium"
                    android:includeFontPadding="false"
                    android:singleLine="true"
                    android:ellipsize="end"
                    tools:text="Loud &amp; Proud" />

                <TextView
                    android:id="@+id/player_info_next_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#B0BACC"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    tools:text="10:00 PM – 11:00 PM" />
            </LinearLayout>
        </LinearLayout>

        <!-- Thin divider line above the controls -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E2A44"
            android:layout_marginHorizontal="48dp" />

        <!-- ── Control bar — 8 buttons evenly spaced ── -->
        <LinearLayout
            android:id="@+id/player_controls_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="8"
            android:paddingHorizontal="48dp"
            android:paddingTop="14dp"
            android:paddingBottom="22dp">

            <!-- 1. Rewind -->
            <LinearLayout
                style="@style/PlayerControlSlot"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btn_player_rewind"
                    style="@style/PlayerControlButton"
                    android:src="@drawable/ic_player_rewind"
                    android:contentDescription="Rewind 10 seconds" />
                <TextView
                    style="@style/PlayerControlLabel"
                    android:text="REWIND" />
            </LinearLayout>

            <!-- 2. Play -->
            <LinearLayout
                style="@style/PlayerControlSlot"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btn_player_playpause"
                    style="@style/PlayerControlButton"
                    android:src="@drawable/ic_player_play"
                    android:contentDescription="Play / Pause" />
                <TextView
                    android:id="@+id/btn_player_playpause_label"
                    style="@style/PlayerControlLabel"
                    android:text="PLAY" />
            </LinearLayout>

            <!-- 3. Fast forward -->
            <LinearLayout
                style="@style/PlayerControlSlot"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btn_player_forward"
                    style="@style/PlayerControlButton"
                    android:src="@drawable/ic_player_forward"
                    android:contentDescription="Fast forward" />
                <TextView
                    style="@style/PlayerControlLabel"
                    android:text="FAST FWD" />
            </LinearLayout>

            <!-- 4. CH UP -->
            <LinearLayout
                style="@style/PlayerControlSlot"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btn_player_chup"
                    style="@style/PlayerControlButton"
                    android:src="@drawable/ic_player_chup"
                    android:contentDescription="Channel up" />
                <TextView
                    style="@style/PlayerControlLabel"
                    android:text="CH UP" />
            </LinearLayout>

            <!-- 5. CH DOWN -->
            <LinearLayout
                style="@style/PlayerControlSlot"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btn_player_chdown"
                    style="@style/PlayerControlButton"
                    android:src="@drawable/ic_player_chdown"
                    android:contentDescription="Channel down" />
                <TextView
                    style="@style/PlayerControlLabel"
                    android:text="CH DOWN" />
            </LinearLayout>

            <!-- 6. SWAP — toggles to the previously-watched channel -->
            <LinearLayout
                style="@style/PlayerControlSlot"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btn_player_swap"
                    style="@style/PlayerControlButton"
                    android:src="@drawable/ic_player_swap"
                    android:contentDescription="Swap to last channel" />
                <TextView
                    style="@style/PlayerControlLabel"
                    android:text="SWAP" />
            </LinearLayout>

            <!-- 7. SUBTITLES -->
            <LinearLayout
                style="@style/PlayerControlSlot"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btn_player_subtitles"
                    style="@style/PlayerControlButton"
                    android:src="@drawable/ic_player_cc"
                    android:contentDescription="Subtitles" />
                <TextView
                    style="@style/PlayerControlLabel"
                    android:text="SUBTITLES" />
            </LinearLayout>

            <!-- 8. FAVORITE -->
            <LinearLayout
                style="@style/PlayerControlSlot"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btn_player_favorite"
                    style="@style/PlayerControlButton"
                    android:src="@drawable/ic_player_favorite"
                    android:contentDescription="Favorite" />
                <TextView
                    style="@style/PlayerControlLabel"
                    android:text="FAVORITE" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ─────────── Status / error text ─────────── -->
    <TextView
        android:id="@+id/player_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:visibility="gone"
        tools:text="" />

    <!-- ─────────── Legacy hidden views (kept so old code paths still resolve) ─────────── -->
    <!-- v2.10 — These IDs are referenced by older PlayerActivity
         code paths.  Keeping them as zero-size hidden TextViews
         prevents NPEs without polluting the new design. -->
    <LinearLayout
        android:id="@+id/info_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone">
        <ImageView android:id="@+id/info_logo"
            android:layout_width="0dp" android:layout_height="0dp" />
        <TextView android:id="@+id/info_channel"
            android:layout_width="0dp" android:layout_height="0dp" />
        <TextView android:id="@+id/info_lcn"
            android:layout_width="0dp" android:layout_height="0dp" />
        <TextView android:id="@+id/info_now_title"
            android:layout_width="0dp" android:layout_height="0dp" />
        <ProgressBar android:id="@+id/info_progress"
            android:layout_width="0dp" android:layout_height="0dp" />
        <TextView android:id="@+id/info_up_next"
            android:layout_width="0dp" android:layout_height="0dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/player_info_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone">
        <ImageView android:id="@+id/player_info_logo_legacy"
            android:layout_width="0dp" android:layout_height="0dp" />
        <TextView android:id="@+id/player_info_channel"
            android:layout_width="0dp" android:layout_height="0dp" />
        <!-- v2.10 — legacy programme/description placeholders.
             Used by the old renderPlayerInfoCard() code path so it
             can never accidentally clobber the visible NOW/NEXT
             panel up top. -->
        <TextView android:id="@+id/player_info_programme_legacy"
            android:layout_width="0dp" android:layout_height="0dp" />
        <TextView android:id="@+id/player_info_description_legacy"
            android:layout_width="0dp" android:layout_height="0dp" />
    </LinearLayout>

    <!-- Legacy buttons referenced in earlier PlayerActivity code -->
    <ImageButton android:id="@+id/btn_player_aspect"
        android:layout_width="0dp" android:layout_height="0dp"
        android:visibility="gone" android:focusable="false"
        android:contentDescription="@null" />
    <ImageButton android:id="@+id/btn_player_info"
        android:layout_width="0dp" android:layout_height="0dp"
        android:visibility="gone" android:focusable="false"
        android:contentDescription="@null" />
</FrameLayout>
