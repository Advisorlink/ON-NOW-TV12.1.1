<?xml version="1.0" encoding="utf-8"?>
<!-- Guide tile — 2 rows per tile.
     Row 1: [ time ] [ programme name (fills) ]
     Row 2: 🔔 PUSH OK TO SET REMINDER
            (text becomes "REMINDER SET" + entire tile gets a
             yellow glow outline ring when the reminder is on,
             via guide_row_bg.xml's state_activated selector).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="6dp">

    <TextView
        android:id="@+id/guide_day_header"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/guide_row_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/guide_row_bg"
        android:focusable="true"
        android:clickable="true"
        android:paddingTop="8dp"
        android:paddingBottom="9dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <!-- Row 1: time · programme name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/guide_time"
                android:layout_width="78dp"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/livetv_accent"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"
                android:maxLines="1"
                android:text="" />

            <!-- legacy hidden -->
            <TextView
                android:id="@+id/guide_ampm"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/guide_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:textColor="@color/livetv_fg"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="" />
        </LinearLayout>

        <!-- Row 2: 🔔 PUSH OK TO SET REMINDER -->
        <LinearLayout
            android:id="@+id/guide_remind_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/guide_remind_bell"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_bell"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/guide_remind"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="monospace"
                android:textColor="@color/livetv_fg_dimmer"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.20"
                android:text="PUSH OK TO SET REMINDER" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
