<?xml version="1.0" encoding="utf-8"?>
<!-- Guide tile — 2 rows per tile.
     Row 1: [ time ] [ programme name (fills) ]
     Row 2: 🔔 PUSH OK TO SET REMINDER  (yellow + "REMINDER SET" when armed)

     v2.9.9 — Shrunk vertical padding 8→4dp, body margin 6→3dp,
     time/title text 13→12sp.  Fits roughly ONE extra row in the
     same vertical real-estate.  Day header now actually styled so
     "TOMORROW · 8 JUN" reads as a divider, not blank space.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="3dp">

    <!-- v2.9.9 — Day divider chip.  Adapter sets it to VISIBLE for
         a "TODAY · 7 JUN" / "TOMORROW · 8 JUN" / "WED · 9 JUN"
         label whenever the next programme crosses midnight.  Sits
         FLUSH between guide rows, NOT inside the tile, so it reads
         as a section header. -->
    <TextView
        android:id="@+id/guide_day_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:background="@drawable/guide_day_header_bg"
        android:fontFamily="monospace"
        android:textColor="@color/livetv_accent"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.22"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/guide_row_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/guide_row_bg"
        android:focusable="true"
        android:clickable="true"
        android:paddingTop="5dp"
        android:paddingBottom="6dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <!-- Row 1: time · programme name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/guide_time"
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/livetv_accent"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"
                android:maxLines="1"
                android:text="" />

            <!-- legacy hidden -->
            <TextView
                android:id="@+id/guide_ampm"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/guide_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:textColor="@color/livetv_fg"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="" />
        </LinearLayout>

        <!-- Row 2: 🔔 PUSH OK TO SET REMINDER -->
        <LinearLayout
            android:id="@+id/guide_remind_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/guide_remind_bell"
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:src="@drawable/ic_bell"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/guide_remind"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="monospace"
                android:textColor="@color/livetv_fg_dimmer"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.20"
                android:text="PUSH OK TO SET REMINDER" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
