<?xml version="1.0" encoding="utf-8"?>
<!-- v2.10.61 — "Coming Up Today" card.  320×128 dp (down from
     340×140) so 5–6 cards fit on a 1080p TV.  Time on the left,
     small per-sport-gradient tile in the middle, title + sport
     tag on the right. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="128dp"
    android:layout_marginEnd="16dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="18dp"
    android:focusable="true"
    android:clickable="true"
    android:background="@drawable/highfly_today_card_bg"
    android:foreground="@drawable/highfly_card_focus_fg">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="start"
        android:layout_marginEnd="14dp">

        <TextView
            android:id="@+id/today_card_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#F5F8FF"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.02"
            android:singleLine="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today"
            android:textColor="#5DC8FF"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.18" />
    </LinearLayout>

    <ImageView
        android:id="@+id/today_card_logo"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:scaleType="centerCrop"
        android:background="@drawable/highfly_card_bg"
        android:clipToOutline="true"
        android:layout_marginEnd="12dp"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/today_card_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F5F8FF"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:lineSpacingExtra="1dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/today_card_sport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#7A8AB2"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.12"
            android:layout_marginTop="5dp"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
