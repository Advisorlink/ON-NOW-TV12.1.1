<?xml version="1.0" encoding="utf-8"?>
<!-- v2.10.59 — Sport-filter chip.  Circular icon + label beneath. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:layout_marginEnd="14dp"
    android:focusable="true"
    android:clickable="true">

    <FrameLayout
        android:id="@+id/sport_chip_circle"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/highfly_sport_chip_bg">

        <TextView
            android:id="@+id/sport_chip_initial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="#F5F8FF"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium" />
    </FrameLayout>

    <TextView
        android:id="@+id/sport_chip_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#C2CEE3"
        android:textSize="12sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.04" />
</LinearLayout>
