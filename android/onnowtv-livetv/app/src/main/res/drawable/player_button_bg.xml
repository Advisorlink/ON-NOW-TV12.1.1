<?xml version="1.0" encoding="utf-8"?>
<!-- Focus state for the player control buttons.  Idle = translucent
     navy capsule; focus = solid neon-blue ring. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="oval">
            <solid android:color="#335DC8FF" />
            <stroke android:width="2dp" android:color="#5DC8FF" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#665DC8FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#CC0B111E" />
            <stroke android:width="1dp" android:color="#1E2A44" />
        </shape>
    </item>
</selector>
