<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/livetv_bg_focused" />
            <corners android:radius="14dp" />
            <stroke android:width="3dp" android:color="#5C9CFF" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/livetv_bg_live" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="@color/livetv_card_border" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/livetv_bg_card" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="@color/livetv_card_border" />
        </shape>
    </item>
</selector>
