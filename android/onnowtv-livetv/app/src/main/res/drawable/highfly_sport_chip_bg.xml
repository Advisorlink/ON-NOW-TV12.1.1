<?xml version="1.0" encoding="utf-8"?>
<!-- Sport-filter chip background.  Default: muted navy circle.
     Focused / selected: cyan-bordered circle with subtle fill. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="oval">
            <solid android:color="#1B2540" />
            <stroke android:width="2dp" android:color="#5DC8FF" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="oval">
            <solid android:color="#1B2540" />
            <stroke android:width="2dp" android:color="#5DC8FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#10172A" />
            <stroke android:width="1dp" android:color="#2A3552" />
        </shape>
    </item>
</selector>
