<?xml version="1.0" encoding="utf-8"?>
<!--
    Guide row background.

    Four visual states:
      • activated + focused : GREEN glow ring (reminder set, row highlighted)
      • activated           : GREEN outline  (reminder set)
      • focused             : cyan accent outline
      • default             : subtle dark capsule

    `isActivated = true` is toggled from GuideRowAdapter when the
    user pushes OK to set a reminder.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Reminder set AND focused: bright green glow -->
    <item android:state_activated="true" android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#142219" />
            <corners android:radius="14dp" />
            <stroke android:width="2dp" android:color="@color/livetv_reminder_yellow" />
        </shape>
    </item>

    <!-- Reminder set: solid green outline -->
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="#0E1A14" />
            <corners android:radius="14dp" />
            <stroke android:width="2dp" android:color="@color/livetv_reminder_yellow" />
        </shape>
    </item>

    <!-- Focused (D-pad highlight) -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/livetv_bg_focused" />
            <corners android:radius="14dp" />
            <stroke android:width="3dp" android:color="#5C9CFF" />
        </shape>
    </item>

    <!-- Default -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0E1422" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#1AFFFFFF" />
        </shape>
    </item>
</selector>
