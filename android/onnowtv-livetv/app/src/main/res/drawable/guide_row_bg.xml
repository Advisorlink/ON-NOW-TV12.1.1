<?xml version="1.0" encoding="utf-8"?>
<!-- Each guide row sits in its own rounded card to match the
     SKY HISTORY 2 reference where every "OK TO REMIND" entry is
     visibly boxed in its own subtle dark capsule. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/livetv_bg_focused" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="@color/livetv_accent" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0E1422" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#1AFFFFFF" />
        </shape>
    </item>
</selector>
