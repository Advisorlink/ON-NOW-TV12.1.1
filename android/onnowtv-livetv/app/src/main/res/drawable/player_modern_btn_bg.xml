<?xml version="1.0" encoding="utf-8"?>
<!-- v2.9.9 Modern player control button — circular glass pill that
     glows neon-blue on remote-focus.  Default is a subtle dark
     glass; focused/hover/pressed lights up. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Remote focused — primary affordance for TV navigation -->
    <item android:state_focused="true">
        <shape android:shape="oval">
            <solid android:color="#1A5DC8FF" />
            <stroke android:width="2dp" android:color="#5DC8FF" />
        </shape>
    </item>
    <!-- Touch pressed -->
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#2A5DC8FF" />
            <stroke android:width="2dp" android:color="#A6E2FF" />
        </shape>
    </item>
    <!-- Default — quiet glass -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#80111A2A" />
            <stroke android:width="1dp" android:color="#26344E" />
        </shape>
    </item>
</selector>
