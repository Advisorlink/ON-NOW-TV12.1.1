<?xml version="1.0" encoding="utf-8"?>
<!-- v2.10.1 Programme progress bar — chunky cyan fill, dark unfilled
     track.  Sits beneath the info row spanning from the cyan accent
     bar all the way to the LIVE caption on the right edge. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <corners android:radius="2dp" />
            <solid android:color="#2A3548" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="2dp" />
                <solid android:color="#5DC8FF" />
            </shape>
        </clip>
    </item>
</layer-list>
