<?xml version="1.0" encoding="utf-8"?>
<!-- Dialog card background: deep glass with a subtle blue rim.
     Inspired by the Vesper Movies/TV modal aesthetic — rounded
     corners, soft inner highlight, dark glass body. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="#0C111C" />
            <stroke android:width="1dp" android:color="#1F2A45" />
        </shape>
    </item>
    <!-- Inner top highlight — gives the card a "glass" feel. -->
    <item android:height="2dp" android:gravity="top">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="#2A3A66" />
        </shape>
    </item>
</layer-list>
