<?xml version="1.0" encoding="utf-8"?>
<!-- Dark navy card with rounded corners and a thin outer border —
     the standard surface for every menu / dialog in the Live TV
     app.  Matches the EPG sidebar / preview overlay aesthetic. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="14dp" />
    <solid android:color="#0B111E" />
    <stroke android:width="1dp" android:color="#1E2A44" />
</shape>
