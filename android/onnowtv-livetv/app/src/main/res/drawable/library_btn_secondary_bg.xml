<?xml version="1.0" encoding="utf-8"?>
<!-- Secondary "Cancel" button — outlined, becomes a soft fill on focus. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#1F2A45" />
            <stroke android:width="2dp" android:color="#5C9CFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#11182A" />
            <stroke android:width="1dp" android:color="#1F2A45" />
        </shape>
    </item>
</selector>
