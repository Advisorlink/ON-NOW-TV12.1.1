<?xml version="1.0" encoding="utf-8"?>
<!-- v2.9.7 Login input field — wider radius, deeper navy, brighter
     focus glow.  Built specifically for the redesigned login card.  -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#101A2E" />
            <stroke android:width="2dp" android:color="#5DC8FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#0C1422" />
            <stroke android:width="1dp" android:color="#1E2A44" />
        </shape>
    </item>
</selector>
