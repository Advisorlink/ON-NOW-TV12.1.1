<?xml version="1.0" encoding="utf-8"?>
<!-- Background for the "Add Collection" virtual tile: deep navy with
     a dashed neon-blue border — visually invites the user to click,
     never competes with the AI cover artwork on real tiles. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="14dp" />
    <solid android:color="#0E1422" />
    <stroke
        android:width="1.5dp"
        android:color="#5DC8FF"
        android:dashWidth="6dp"
        android:dashGap="5dp" />
</shape>
