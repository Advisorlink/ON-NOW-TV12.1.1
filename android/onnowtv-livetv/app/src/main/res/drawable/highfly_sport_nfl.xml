<?xml version="1.0" encoding="utf-8"?>
<!-- v2.10.61 — NFL / American football fallback poster.  Navy + red
     contrast, NFL-style. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0B1A36"
                android:centerColor="#1B3578"
                android:endColor="#440812"
                android:angle="135"
                android:type="linear" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#33000000"
                android:endColor="#00000000"
                android:angle="270"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
