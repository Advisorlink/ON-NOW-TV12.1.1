<?xml version="1.0" encoding="utf-8"?>
<!-- v2.9.9 Modern player control bar background.
     A floating glass pill anchored above the bottom edge with a
     1px neon-blue top accent stripe.  Drop-shadow effect approximated
     with the dark gradient at the edges. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="40dp" />
            <gradient
                android:angle="90"
                android:startColor="#F0080C18"
                android:endColor="#E61B2641" />
            <stroke android:width="1dp" android:color="#26344E" />
        </shape>
    </item>
    <item
        android:top="0dp"
        android:left="60dp"
        android:right="60dp"
        android:height="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#005DC8FF"
                android:centerColor="#805DC8FF"
                android:endColor="#005DC8FF" />
        </shape>
    </item>
</layer-list>
