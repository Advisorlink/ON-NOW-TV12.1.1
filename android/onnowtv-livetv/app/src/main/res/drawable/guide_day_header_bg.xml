<?xml version="1.0" encoding="utf-8"?>
<!-- v2.9.9 Day-divider chip background for the guide list.
     A subtle navy pill with a left neon-blue accent stripe so the
     "TOMORROW · 8 JUN" header reads at a glance as section start. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <solid android:color="#0F1A30" />
            <stroke android:width="1dp" android:color="#1E2A44" />
        </shape>
    </item>
    <item android:left="0dp" android:top="0dp" android:bottom="0dp" android:width="3dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="4dp"
                android:bottomLeftRadius="4dp" />
            <solid android:color="@color/livetv_accent" />
        </shape>
    </item>
</layer-list>
