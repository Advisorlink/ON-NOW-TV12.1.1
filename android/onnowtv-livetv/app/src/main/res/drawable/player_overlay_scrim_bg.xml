<?xml version="1.0" encoding="utf-8"?>
<!-- v2.10 Bottom info-panel scrim.
     A dark vertical gradient that sits between the live video
     surface and the info+controls overlay so the text reads
     cleanly without obscuring too much of the video. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="90"
        android:startColor="#00000000"
        android:centerColor="#A6000000"
        android:endColor="#F0050810" />
</shape>
