<?xml version="1.0" encoding="utf-8"?>
<!-- v2.10.61 — Baseball fallback poster.  Outfield green to dugout
     dirt brown. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0E2615"
                android:centerColor="#2D7A3D"
                android:endColor="#3B2412"
                android:angle="135"
                android:type="linear" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#33000000"
                android:endColor="#00000000"
                android:angle="270"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
