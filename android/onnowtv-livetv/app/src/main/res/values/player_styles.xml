<?xml version="1.0" encoding="utf-8"?>
<!-- v2.10.3 — Reusable styles for the player control bar.
     Compact sizing so the overall overlay reads as a slim live-TV
     banner (~30 % of screen), not a half-screen takeover. -->
<resources>
    <style name="PlayerControlSlot">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:paddingHorizontal">4dp</item>
        <item name="android:paddingVertical">2dp</item>
    </style>

    <style name="PlayerControlButton">
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:padding">11dp</item>
        <item name="android:background">@drawable/player_modern_btn_bg</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
    </style>

    <style name="PlayerControlLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:textColor">#D6DDEC</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.18</item>
    </style>
</resources>
