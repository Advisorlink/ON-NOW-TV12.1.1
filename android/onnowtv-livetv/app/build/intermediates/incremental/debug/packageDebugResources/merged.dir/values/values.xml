<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="livetv_accent">#FF2535</color>
    <color name="livetv_bg">#06080F</color>
    <color name="livetv_bg_alt">#0A0E1A</color>
    <color name="livetv_bg_card">#0D1525</color>
    <color name="livetv_bg_focused">#18253F</color>
    <color name="livetv_bg_live">#1A2438</color>
    <color name="livetv_blue">#5DC8FF</color>
    <color name="livetv_fg">#F5F7FA</color>
    <color name="livetv_fg_dim">#B0B8C8</color>
    <color name="livetv_fg_dimmer">#6E7888</color>
    <color name="livetv_now_line">#FF2535</color>
    <color name="livetv_row_separator">#11FFFFFF</color>
    <item name="tag_scroll_sync_listener" type="id"/>
    <string name="app_name">ON NOW V2 Live TV</string>
    <string name="brand_suffix">Live TV</string>
    <string name="brand_v2">V2</string>
    <string name="live_pill">LIVE</string>
    <string name="loading_guide">Loading guide…</string>
    <string name="no_programme">No programme info</string>
    <string name="today">Today</string>
    <string name="up_next">UP NEXT</string>
    <style name="Theme.OnNowLiveTV" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/livetv_bg</item>
        <item name="android:statusBarColor">@color/livetv_bg</item>
        <item name="android:navigationBarColor">@color/livetv_bg</item>
        <item name="colorPrimary">@color/livetv_accent</item>
        <item name="colorPrimaryDark">@color/livetv_bg_alt</item>
        <item name="colorAccent">@color/livetv_accent</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>
    <style name="Theme.OnNowLiveTV.NoActionBar" parent="Theme.OnNowLiveTV">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    <style name="Theme.OnNowLiveTV.Splash" parent="Theme.OnNowLiveTV.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_gradient</item>
        <item name="android:statusBarColor">@color/livetv_bg</item>
        <item name="android:navigationBarColor">@color/livetv_bg</item>
    </style>
