<?xml version="1.0" encoding="utf-8"?>
<!--
    Single EPG row: channel rail item on the left (fixed width),
    then a horizontal RecyclerView of programme cells.

    Height = 64 dp (matches the FTA grid spec).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:descendantFocusability="afterDescendants"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:focusable="false">

    <!-- Channel rail (logo + LCN) — focusable so the user can land
         on a channel by D-padding into the first column. -->
    <FrameLayout
        android:id="@+id/channel_rail_item"
        android:layout_width="104dp"
        android:layout_height="match_parent"
        android:background="@drawable/channel_bg"
        android:focusable="true"
        android:clickable="true">

        <ImageView
            android:id="@+id/channel_logo"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/channel_lcn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="2dp"
            android:textColor="@color/livetv_fg_dim"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:text="" />

        <TextView
            android:id="@+id/channel_name_fallback"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="@color/livetv_fg"
            android:textSize="13sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="2"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:visibility="gone"
            android:text="" />
    </FrameLayout>

    <!-- Horizontal programme grid for this channel -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/programmes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:descendantFocusability="afterDescendants"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:overScrollMode="never" />
</LinearLayout>
