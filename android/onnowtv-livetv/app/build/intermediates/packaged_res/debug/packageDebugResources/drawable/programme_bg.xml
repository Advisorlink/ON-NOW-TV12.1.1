<?xml version="1.0" encoding="utf-8"?>
<!-- Programme cell background.  Focused state owns the bright
     red border + glow; non-focused is the dark card colour. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/livetv_bg_focused" />
                    <corners android:radius="6dp" />
                    <stroke android:width="2dp" android:color="@color/livetv_accent" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/livetv_bg_focused" />
            <corners android:radius="6dp" />
            <stroke android:width="1dp" android:color="@color/livetv_accent" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/livetv_bg_card" />
            <corners android:radius="6dp" />
            <stroke android:width="1dp" android:color="@color/livetv_row_separator" />
        </shape>
    </item>
</selector>
