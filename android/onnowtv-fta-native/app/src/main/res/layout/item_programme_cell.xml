<?xml version="1.0" encoding="utf-8"?>
<!-- One programme cell inside the timeline strip.  Width is set
     programmatically based on programme duration. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:background="@drawable/cell_bg"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:focusable="true"
    android:clickable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/cell_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/fta_blue"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.14"
            android:text="" />

        <TextView
            android:id="@+id/cell_next_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingTop="1dp"
            android:paddingBottom="1dp"
            android:background="@drawable/next_pill_bg"
            android:fontFamily="monospace"
            android:textColor="@color/fta_bg"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.20"
            android:visibility="gone"
            android:text="NEXT" />
    </LinearLayout>

    <TextView
        android:id="@+id/cell_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/fta_fg"
        android:textSize="12sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="" />
</LinearLayout>
