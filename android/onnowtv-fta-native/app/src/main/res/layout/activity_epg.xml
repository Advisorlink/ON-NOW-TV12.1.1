<?xml version="1.0" encoding="utf-8"?>
<!--
    FTA NATIVE — EPG screen (Phase 4 — banner layout).

    Per operator direction Feb 13 2026:
       "Image (16:9 preview) in top-left, description beside it
        with a nice heading, coming-up-next beside that. EPG goes
        underneath the whole banner at full width."

    Vertical layout:
       [ topbar (clock, tabs, city) ]
       [ banner row — preview | info | up next ]
       [ time ticks ]
       [ EPG grid — full width ]

    The categories slide-out + side nav are pinned to the LEFT edge
    as an overlay so the EPG below still spans the full screen
    width when they're hidden.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fta_bg">

    <!-- ───────── ROOT VERTICAL STACK ───────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- TOPBAR -->
        <LinearLayout
            android:id="@+id/topbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/fta_topbar_h"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:background="#080C18">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand"
                android:textColor="@color/fta_blue"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"
                android:shadowColor="#665DC8FF"
                android:shadowDx="0" android:shadowDy="0" android:shadowRadius="14" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/brand_suffix"
                android:textColor="@color/fta_fg"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.01" />

            <LinearLayout
                android:id="@+id/tabs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="28dp" />

            <TextView
                android:id="@+id/active_cat_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="4dp" android:paddingBottom="4dp"
                android:background="@drawable/next_pill_bg"
                android:textColor="@color/fta_bg"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.22"
                android:visibility="gone"
                android:text="" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/city_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:paddingTop="6dp" android:paddingBottom="6dp"
                android:background="@drawable/time_chip_bg"
                android:textColor="@color/fta_blue"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.22"
                android:focusable="true"
                android:clickable="true"
                android:text="BRISBANE" />

            <TextView
                android:id="@+id/clock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:textColor="@color/fta_fg"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.08"
                android:text="" />
        </LinearLayout>

        <!-- ───────── BANNER ROW (preview · description · up next) ───────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/fta_banner_h"
            android:orientation="horizontal"
            android:paddingStart="@dimen/fta_side_rail_w"
            android:paddingEnd="22dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:gravity="top">

            <!-- 16:9 PREVIEW CARD -->
            <FrameLayout
                android:id="@+id/preview_card"
                android:layout_width="@dimen/fta_banner_preview_w"
                android:layout_height="match_parent"
                android:background="@drawable/preview_card_bg"
                android:focusable="true"
                android:clickable="true"
                android:foreground="@drawable/preview_card_focus">

                <ImageView
                    android:id="@+id/preview_art"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@null" />

                <ImageView
                    android:id="@+id/preview_art_overlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:alpha="0"
                    android:contentDescription="@null" />

                <androidx.media3.ui.PlayerView
                    android:id="@+id/preview_player"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="invisible"
                    app:resize_mode="fill"
                    app:use_controller="false"
                    app:show_buffering="never" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/preview_gradient" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="10dp"
                    android:paddingStart="9dp" android:paddingEnd="9dp"
                    android:paddingTop="4dp" android:paddingBottom="4dp"
                    android:background="@drawable/live_pill_bg"
                    android:text="● LIVE"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.20"
                    android:shadowColor="#88FF2535"
                    android:shadowDx="0" android:shadowDy="0" android:shadowRadius="6" />

                <TextView
                    android:id="@+id/preview_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="10dp"
                    android:paddingStart="9dp" android:paddingEnd="9dp"
                    android:paddingTop="4dp" android:paddingBottom="4dp"
                    android:background="@drawable/hint_pill_bg"
                    android:text="▶  PRESS OK"
                    android:textColor="@color/fta_bg"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.20" />

                <!-- Channel rail at the bottom: logo + LCN -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="10dp">

                    <ImageView
                        android:id="@+id/preview_logo"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:scaleType="centerInside"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/preview_channel_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.14"
                        android:shadowColor="#80000000"
                        android:shadowDx="0" android:shadowDy="1" android:shadowRadius="4"
                        android:text="" />
                </LinearLayout>
            </FrameLayout>

            <!-- DESCRIPTION CARD -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="18dp"
                android:orientation="vertical"
                android:background="@drawable/banner_card_bg"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <TextView
                    android:id="@+id/info_eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/fta_blue"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.32"
                    android:text="NOW PLAYING" />

                <TextView
                    android:id="@+id/info_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:lineSpacingMultiplier="0.97"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02"
                    android:shadowColor="#80000000"
                    android:shadowDx="0" android:shadowDy="1" android:shadowRadius="5"
                    android:text="" />

                <TextView
                    android:id="@+id/info_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/fta_blue_bright"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.14"
                    android:text="" />

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/info_chips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:flexWrap="wrap"
                    app:alignItems="center" />

                <TextView
                    android:id="@+id/info_synopsis"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="10dp"
                    android:textColor="#CCD4E0"
                    android:textSize="12sp"
                    android:lineSpacingExtra="3dp"
                    android:fontFamily="sans-serif"
                    android:maxLines="4"
                    android:ellipsize="end"
                    android:text="" />
            </LinearLayout>

            <!-- COMING UP NEXT CARD -->
            <LinearLayout
                android:id="@+id/upnext_block"
                android:layout_width="@dimen/fta_banner_upnext_w"
                android:layout_height="match_parent"
                android:layout_marginStart="18dp"
                android:orientation="vertical"
                android:background="@drawable/upnext_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMING UP NEXT"
                    android:textColor="@color/fta_blue"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.32" />

                <TextView
                    android:id="@+id/upnext_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/fta_blue_bright"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.10"
                    android:text="—" />

                <TextView
                    android:id="@+id/upnext_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/fta_fg"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:lineSpacingMultiplier="1.04"
                    android:maxLines="3"
                    android:ellipsize="end"
                    android:text="" />

                <TextView
                    android:id="@+id/upnext_desc"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="6dp"
                    android:textColor="#A8B3C2"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="3"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif"
                    android:text="" />
            </LinearLayout>
        </LinearLayout>

        <!-- TIME TICKS HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <View
                android:layout_width="@dimen/fta_channel_rail_w"
                android:layout_height="32dp"
                android:background="#080C18" />

            <HorizontalScrollView
                android:id="@+id/ticks_scroll"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:scrollbars="none"
                android:fillViewport="false">

                <FrameLayout
                    android:id="@+id/ticks_strip"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:background="#080C18" />
            </HorizontalScrollView>
        </LinearLayout>

        <!-- EPG GRID — full width -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/grid_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:descendantFocusability="afterDescendants"
                android:focusable="false"
                android:overScrollMode="never"
                android:clipToPadding="false" />

            <View
                android:id="@+id/now_line"
                android:layout_width="2dp"
                android:layout_height="match_parent"
                android:layout_marginStart="0dp"
                android:background="@color/fta_now_red"
                android:visibility="invisible" />

            <LinearLayout
                android:id="@+id/loader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <ProgressBar
                    android:layout_width="40dp"
                    android:layout_height="40dp" />

                <TextView
                    android:id="@+id/loader_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/fta_fg_dim"
                    android:textSize="12sp"
                    android:letterSpacing="0.22"
                    android:text="LOADING FREE-TO-AIR EPG…" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- ───────── LEFT SIDE NAV (overlay so banner + grid stay full width) ───────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/side_nav"
        android:layout_width="@dimen/fta_side_rail_w"
        android:layout_height="match_parent"
        android:background="#0A0E1A"
        android:paddingTop="28dp"
        android:paddingBottom="28dp"
        android:descendantFocusability="afterDescendants"
        android:focusable="false"
        android:overScrollMode="never" />

    <!-- ───────── CATEGORIES SLIDE-OUT (overlay) ───────── -->
    <LinearLayout
        android:id="@+id/cat_panel"
        android:layout_width="@dimen/fta_cat_panel_w"
        android:layout_height="match_parent"
        android:layout_marginStart="@dimen/fta_side_rail_w"
        android:orientation="vertical"
        android:background="@drawable/category_panel_bg"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="22dp"
            android:paddingBottom="14dp"
            android:text="CATEGORIES"
            android:textColor="@color/fta_blue"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.30" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/cat_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:descendantFocusability="afterDescendants"
            android:focusable="false"
            android:overScrollMode="never" />
    </LinearLayout>
</FrameLayout>
