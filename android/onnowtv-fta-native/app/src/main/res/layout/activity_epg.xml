<?xml version="1.0" encoding="utf-8"?>
<!--
    FTA NATIVE — EPG screen (Phase 3 — cinematic sidebar redesign).

    The Sidebar is now built around a single 16:9 cinematic HERO
    card that occupies the top half of the sidebar.  TMDB backdrop
    art fills the entire card; programme title + meta + progress
    bar sit at the bottom under a strong dark gradient so they're
    legible over any artwork.  A focus-only cyan rim glow gives the
    "Apple TV up next card" feel.

    Below the hero is an INFO PLATE that visually melds into the
    bottom of the card (no gap, matching gradient colour) — it
    carries:
      • channel logo strip (logo + LCN + name) on a dark transparent
        rail
      • multi-line synopsis as the primary descriptor
      • a chip rail (rating · category · HD · CC) with subtle 1 px
        cyan outlines
      • a "COMING UP NEXT" rail with a cyan accent stripe

    Horizontal layout:
      [ side nav (88dp) ]
      [ cat panel slide-out (260dp) ]
      [ sidebar (360dp) ]
      [ topbar + ticks + grid ]
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/fta_bg">

    <!-- SIDE NAV -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/side_nav"
        android:layout_width="@dimen/fta_side_rail_w"
        android:layout_height="match_parent"
        android:background="#0A0E1A"
        android:paddingTop="28dp"
        android:paddingBottom="28dp"
        android:descendantFocusability="afterDescendants"
        android:focusable="false"
        android:overScrollMode="never" />

    <!-- CATEGORIES SLIDE-OUT -->
    <LinearLayout
        android:id="@+id/cat_panel"
        android:layout_width="@dimen/fta_cat_panel_w"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/category_panel_bg"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="22dp"
            android:paddingBottom="14dp"
            android:text="CATEGORIES"
            android:textColor="@color/fta_blue"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.30" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/cat_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:descendantFocusability="afterDescendants"
            android:focusable="false"
            android:overScrollMode="never" />
    </LinearLayout>

    <!-- SIDEBAR -->
    <ScrollView
        android:id="@+id/sidebar_scroll"
        android:layout_width="@dimen/fta_sidebar_w"
        android:layout_height="match_parent"
        android:background="#06090F"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="22dp">

            <!-- ───────── CINEMATIC HERO CARD ───────── -->
            <FrameLayout
                android:id="@+id/preview_card"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:background="@drawable/preview_card_bg"
                android:focusable="true"
                android:clickable="true"
                android:foreground="@drawable/preview_card_focus">

                <!-- TMDB backdrop (default).  Channel logo is used as
                     a fallback if TMDB has no art for the title. -->
                <ImageView
                    android:id="@+id/preview_art"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@null" />

                <!-- Cross-fade target — second image view layered on
                     top so we can crossfade between channels without
                     a flash to black. -->
                <ImageView
                    android:id="@+id/preview_art_overlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:alpha="0"
                    android:contentDescription="@null" />

                <!-- Live HLS player — only visible after explicit OK. -->
                <androidx.media3.ui.PlayerView
                    android:id="@+id/preview_player"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="invisible"
                    app:resize_mode="fill"
                    app:use_controller="false"
                    app:show_buffering="never" />

                <!-- Bottom gradient for title legibility. -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/preview_gradient" />

                <!-- LIVE pill (top-left, red gradient + glow). -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="12dp"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:paddingTop="4dp" android:paddingBottom="4dp"
                    android:background="@drawable/live_pill_bg"
                    android:text="● LIVE"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.20"
                    android:shadowColor="#88FF2535"
                    android:shadowDx="0" android:shadowDy="0" android:shadowRadius="6" />

                <!-- "Press OK to play" hint (top-right, cyan). -->
                <TextView
                    android:id="@+id/preview_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_marginEnd="12dp"
                    android:layout_marginTop="12dp"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:paddingTop="4dp" android:paddingBottom="4dp"
                    android:background="@drawable/hint_pill_bg"
                    android:text="▶  PRESS OK"
                    android:textColor="@color/fta_bg"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.20" />

                <!-- Bottom hero text: programme title + time + progress. -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/preview_eyebrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/fta_blue"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.30"
                        android:text="NOW PLAYING" />

                    <TextView
                        android:id="@+id/preview_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="0.95"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.02"
                        android:shadowColor="#80000000"
                        android:shadowDx="0" android:shadowDy="1" android:shadowRadius="6"
                        android:text="" />

                    <TextView
                        android:id="@+id/preview_meta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:textColor="#E0E8F2"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.10"
                        android:text="" />

                    <View
                        android:id="@+id/preview_progress_track"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/progress_track_bg" />

                    <View
                        android:id="@+id/preview_progress_bar"
                        android:layout_width="0dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="-3dp"
                        android:background="@color/fta_blue" />
                </LinearLayout>
            </FrameLayout>

            <!-- ───────── INFO PLATE (synopsis + chips) ───────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/info_card_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:layout_marginTop="-1dp">

                <!-- Channel strip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/info_logo"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerInside"
                        android:contentDescription="@null" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/info_lcn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/fta_blue"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.18"
                            android:text="" />

                        <TextView
                            android:id="@+id/info_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/fta_fg"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/info_fav_glyph"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textColor="@color/fta_blue"
                        android:textSize="20sp"
                        android:visibility="gone"
                        android:shadowColor="#665DC8FF"
                        android:shadowDx="0" android:shadowDy="0" android:shadowRadius="10" />
                </LinearLayout>

                <!-- Synopsis -->
                <TextView
                    android:id="@+id/info_synopsis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="#C0CADA"
                    android:textSize="12sp"
                    android:lineSpacingExtra="3dp"
                    android:fontFamily="sans-serif"
                    android:maxLines="6"
                    android:ellipsize="end"
                    android:text="" />

                <!-- Chips -->
                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/info_chips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:flexWrap="wrap"
                    app:alignItems="center" />
            </LinearLayout>

            <!-- ───────── COMING UP NEXT ───────── -->
            <LinearLayout
                android:id="@+id/upnext_block"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="14dp"
                android:padding="14dp"
                android:background="@drawable/upnext_bg"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMING UP NEXT"
                    android:textColor="@color/fta_blue"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.30" />

                <TextView
                    android:id="@+id/upnext_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/fta_fg"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:text="" />

                <TextView
                    android:id="@+id/upnext_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textColor="@color/fta_fg_dim"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.10"
                    android:text="" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ───────── MAIN (topbar + grid) ───────── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Topbar -->
        <LinearLayout
            android:id="@+id/topbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/fta_topbar_h"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:background="#080C18">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand"
                android:textColor="@color/fta_blue"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"
                android:shadowColor="#665DC8FF"
                android:shadowDx="0" android:shadowDy="0" android:shadowRadius="14" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/brand_suffix"
                android:textColor="@color/fta_fg"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.01" />

            <LinearLayout
                android:id="@+id/tabs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="28dp" />

            <TextView
                android:id="@+id/active_cat_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="4dp" android:paddingBottom="4dp"
                android:background="@drawable/next_pill_bg"
                android:textColor="@color/fta_bg"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.22"
                android:visibility="gone"
                android:text="" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/city_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:paddingTop="6dp" android:paddingBottom="6dp"
                android:background="@drawable/time_chip_bg"
                android:textColor="@color/fta_blue"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.22"
                android:focusable="true"
                android:clickable="true"
                android:text="BRISBANE" />

            <TextView
                android:id="@+id/clock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:textColor="@color/fta_fg"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.08"
                android:text="" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <View
                android:layout_width="@dimen/fta_channel_rail_w"
                android:layout_height="32dp"
                android:background="#080C18" />

            <HorizontalScrollView
                android:id="@+id/ticks_scroll"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:scrollbars="none"
                android:fillViewport="false">

                <FrameLayout
                    android:id="@+id/ticks_strip"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:background="#080C18" />
            </HorizontalScrollView>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/grid_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:descendantFocusability="afterDescendants"
                android:focusable="false"
                android:overScrollMode="never"
                android:clipToPadding="false" />

            <View
                android:id="@+id/now_line"
                android:layout_width="2dp"
                android:layout_height="match_parent"
                android:layout_marginStart="0dp"
                android:background="@color/fta_now_red"
                android:visibility="invisible" />

            <LinearLayout
                android:id="@+id/loader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <ProgressBar
                    android:layout_width="40dp"
                    android:layout_height="40dp" />

                <TextView
                    android:id="@+id/loader_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/fta_fg_dim"
                    android:textSize="12sp"
                    android:letterSpacing="0.22"
                    android:text="LOADING FREE-TO-AIR EPG…" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
