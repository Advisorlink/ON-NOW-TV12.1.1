<?xml version="1.0" encoding="utf-8"?>
<!--
    FTA NATIVE — EPG screen (Phase 2).

    Layout:
      [ SIDE NAV (88dp) ][ CATEGORIES PANEL (260dp, slide-out) ]
      [ TOPBAR + ticks header + grid body + preview pane overlay ]

    The categories panel is hidden by default (visibility=GONE) and
    toggled by the "Categories" side-rail icon.  When visible it
    pushes the grid right, mirroring the WebView FTA UX where the
    submenu sits to the right of the rail.

    The preview pane is an overlay in the top-right of the grid
    body — a small ExoPlayer that auto-tunes to the focused channel
    after an 800 ms debounce.  Tap a programme → opens the full
    PlayerActivity.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/fta_bg">

    <!-- ───────── SIDE NAV ───────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/side_nav"
        android:layout_width="@dimen/fta_side_rail_w"
        android:layout_height="match_parent"
        android:background="#0A0E1A"
        android:paddingTop="28dp"
        android:paddingBottom="28dp"
        android:descendantFocusability="afterDescendants"
        android:focusable="false"
        android:overScrollMode="never" />

    <!-- ───────── CATEGORIES SLIDE-OUT PANEL ───────── -->
    <LinearLayout
        android:id="@+id/cat_panel"
        android:layout_width="@dimen/fta_cat_panel_w"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/category_panel_bg"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="22dp"
            android:paddingBottom="14dp"
            android:text="CATEGORIES"
            android:textColor="@color/fta_blue"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.30" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/cat_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:descendantFocusability="afterDescendants"
            android:focusable="false"
            android:overScrollMode="never" />
    </LinearLayout>

    <!-- ───────── MAIN CONTENT ───────── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Topbar -->
        <LinearLayout
            android:id="@+id/topbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/fta_topbar_h"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:background="#080C18">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand"
                android:textColor="@color/fta_blue"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"
                android:shadowColor="#665DC8FF"
                android:shadowDx="0" android:shadowDy="0" android:shadowRadius="14" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/brand_suffix"
                android:textColor="@color/fta_fg"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.01" />

            <!-- Tabs (Live / Favourites) -->
            <LinearLayout
                android:id="@+id/tabs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="32dp" />

            <!-- Currently-selected category chip (when a non-live
                 category is active, e.g. "KIDS" or "SPORT"). -->
            <TextView
                android:id="@+id/active_cat_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="4dp" android:paddingBottom="4dp"
                android:background="@drawable/next_pill_bg"
                android:textColor="@color/fta_bg"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.22"
                android:visibility="gone"
                android:text="" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- City chip — focusable, click opens the city picker. -->
            <TextView
                android:id="@+id/city_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:paddingTop="6dp" android:paddingBottom="6dp"
                android:background="@drawable/time_chip_bg"
                android:textColor="@color/fta_blue"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.22"
                android:focusable="true"
                android:clickable="true"
                android:text="BRISBANE" />

            <TextView
                android:id="@+id/clock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:textColor="@color/fta_fg"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.08"
                android:text="" />
        </LinearLayout>

        <!-- Time-ticks header row (hour labels above the grid). -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Spacer to align with the channel rail. -->
            <View
                android:layout_width="@dimen/fta_channel_rail_w"
                android:layout_height="32dp"
                android:background="#080C18" />

            <HorizontalScrollView
                android:id="@+id/ticks_scroll"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:scrollbars="none"
                android:fillViewport="false">

                <FrameLayout
                    android:id="@+id/ticks_strip"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:background="#080C18" />
            </HorizontalScrollView>
        </LinearLayout>

        <!-- Grid body -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/grid_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:descendantFocusability="afterDescendants"
                android:focusable="false"
                android:overScrollMode="never"
                android:clipToPadding="false" />

            <!-- NOW vertical red line — positioned by EpgActivity. -->
            <View
                android:id="@+id/now_line"
                android:layout_width="2dp"
                android:layout_height="match_parent"
                android:layout_marginStart="0dp"
                android:background="@color/fta_now_red"
                android:visibility="invisible" />

            <!-- ───────── PREVIEW PANE (top-right overlay) ───────── -->
            <LinearLayout
                android:id="@+id/preview_card"
                android:layout_width="@dimen/fta_preview_w"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="22dp"
                android:orientation="vertical"
                android:background="@drawable/preview_card_bg"
                android:padding="6dp"
                android:visibility="invisible">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/fta_preview_h">

                    <androidx.media3.ui.PlayerView
                        android:id="@+id/preview_player"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:resize_mode="fill"
                        app:use_controller="false"
                        app:show_buffering="never" />

                    <!-- "TUNING…" overlay shown while the preview
                         player is buffering the new channel. -->
                    <TextView
                        android:id="@+id/preview_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.22"
                        android:visibility="gone"
                        android:text="TUNING…" />
                </FrameLayout>

                <TextView
                    android:id="@+id/preview_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/fta_fg"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="" />

                <TextView
                    android:id="@+id/preview_sub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/fta_fg_dim"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.10"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="" />
            </LinearLayout>

            <!-- Loader -->
            <LinearLayout
                android:id="@+id/loader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <ProgressBar
                    android:layout_width="40dp"
                    android:layout_height="40dp" />

                <TextView
                    android:id="@+id/loader_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/fta_fg_dim"
                    android:textSize="12sp"
                    android:letterSpacing="0.22"
                    android:text="LOADING FREE-TO-AIR EPG…" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
