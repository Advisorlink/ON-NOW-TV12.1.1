<?xml version="1.0" encoding="utf-8"?>
<!-- FTA splash gradient — red → orange → amber, matches the
     WebView FTA splash so the two builds feel identical on
     launch. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#B11919"
                android:centerColor="#E04A1A"
                android:endColor="#F5A623"
                android:angle="135"
                android:type="linear" />
        </shape>
    </item>
    <!-- Soft inner vignette for depth. -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00000000"
                android:centerColor="#00000000"
                android:endColor="#55000000"
                android:type="radial"
                android:gradientRadius="600dp" />
        </shape>
    </item>
</layer-list>
