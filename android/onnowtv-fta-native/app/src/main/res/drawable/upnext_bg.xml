<?xml version="1.0" encoding="utf-8"?>
<!-- "Coming up next" cinema rail.  Subtle off-black surface with
     a cyan top accent bar, no rounded corners — sits flush at the
     bottom of the sidebar like a chapter selector. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0C1322" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#1F2E4A" />
        </shape>
    </item>
    <!-- Top accent stripe — cyan glow line -->
    <item android:height="2dp" android:gravity="top">
        <shape android:shape="rectangle">
            <solid android:color="@color/fta_blue" />
        </shape>
    </item>
</layer-list>
