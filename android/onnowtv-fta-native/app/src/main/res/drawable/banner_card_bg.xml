<?xml version="1.0" encoding="utf-8"?>
<!-- Background plate for the description card in the banner row.
     Cyan-tinted glass surface with a soft outline so it feels
     premium and matches the cinematic backdrop card next to it. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#FF101728"
        android:centerColor="#FF0B1322"
        android:endColor="#FF080C18"
        android:angle="270" />
    <corners android:radius="14dp" />
    <stroke android:width="1dp" android:color="#1A5DC8FF" />
</shape>
