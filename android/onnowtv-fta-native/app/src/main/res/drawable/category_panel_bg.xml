<?xml version="1.0" encoding="utf-8"?>
<!-- Slide-out categories panel background — solid navy with a
     subtle cyan glow on the right edge so it visually separates
     from the EPG body. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#080C18" />
        </shape>
    </item>
    <item android:width="2dp" android:gravity="end">
        <shape android:shape="rectangle">
            <solid android:color="#1AFFFFFF" />
        </shape>
    </item>
</layer-list>
