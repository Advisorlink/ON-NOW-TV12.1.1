<?xml version="1.0" encoding="utf-8"?>
<!-- Preview-pane outer card — rounded corners + cyan-tinted border
     so the inline preview reads as a distinct UI element on top of
     the EPG. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#000000" />
    <corners android:radius="10dp" />
    <stroke android:width="1dp" android:color="#335DC8FF" />
</shape>
