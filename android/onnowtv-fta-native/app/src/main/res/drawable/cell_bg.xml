<?xml version="1.0" encoding="utf-8"?>
<!-- Programme cell background.  Cyan focus ring matches the rest
     of the design system. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/fta_bg_focused" />
            <corners android:radius="10dp" />
            <stroke android:width="2dp" android:color="@color/fta_blue" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/fta_bg_card" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="@color/fta_line" />
        </shape>
    </item>
</selector>
