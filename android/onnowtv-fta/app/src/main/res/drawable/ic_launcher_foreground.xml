<?xml version="1.0" encoding="utf-8"?>
<!--
    Antenna / broadcast tower glyph on the adaptive-icon canvas.
    Matches the FTA brand colour (#ff2535) used in the EPG topbar.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Tower mast -->
    <path
        android:pathData="M 53 38 L 55 38 L 60 86 L 48 86 Z"
        android:fillColor="#ff2535" />

    <!-- Inner signal arc -->
    <path
        android:pathData="M 38 36 A 22 22 0 0 1 70 36"
        android:strokeColor="#ff2535"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- Outer signal arc -->
    <path
        android:pathData="M 30 32 A 32 32 0 0 1 78 32"
        android:strokeColor="#ff2535"
        android:strokeWidth="4"
        android:strokeAlpha="0.55"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- Broadcast core dot -->
    <path
        android:pathData="M 54 36 m -4 0 a 4 4 0 1 0 8 0 a 4 4 0 1 0 -8 0"
        android:fillColor="#ff2535" />
</vector>
