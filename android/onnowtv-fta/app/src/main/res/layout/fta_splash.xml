<?xml version="1.0" encoding="utf-8"?>
<!--
    ON NOW V2 — Live TV splash overlay.

    Red gradient background, a centred red TV icon mark, and a big
    "LIVE" wordmark underneath.  Per user feedback: "the splash
    screen needs to be a red TV and it needs to say live underneath
    it".
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fta_splash_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_gradient">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- "ON NOW V2" eyebrow -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ON NOW"
                android:textColor="#FFFFFFFF"
                android:textSize="18sp"
                android:letterSpacing="0.34"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="8" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/splash_pill_dark"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="V2"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.12" />
        </LinearLayout>

        <!-- The big red TV mark -->
        <ImageView
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/splash_tv_mark"
            android:contentDescription="Live TV"
            android:elevation="12dp" />

        <!-- "LIVE" wordmark -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="LIVE"
            android:textColor="#FFFFFFFF"
            android:textSize="72sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.18"
            android:shadowColor="#66000000"
            android:shadowDx="0"
            android:shadowDy="6"
            android:shadowRadius="18" />

        <TextView
            android:id="@+id/fta_splash_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/splash_chip_outline"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="LIVE FREE-TO-AIR TV  •  188 CHANNELS"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.22"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Loading dots -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:layout_marginBottom="58dp"
        android:gravity="center">
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/splash_pill_dark"
            android:alpha="0.95"
            android:layout_marginEnd="6dp" />
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/splash_pill_dark"
            android:alpha="0.6"
            android:layout_marginEnd="6dp" />
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/splash_pill_dark"
            android:alpha="0.3" />
    </LinearLayout>
</FrameLayout>
