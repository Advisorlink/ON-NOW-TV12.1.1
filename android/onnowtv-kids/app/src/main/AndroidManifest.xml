<?xml version="1.0" encoding="utf-8"?>
<!--
    ON NOW V2 KIDS — standalone Kids-mode kiosk wrapper.

    v2.9.3 — corrected per user clarification: we are NOT a home /
    launcher app.  The OnNow Launcher stays as the device's default
    home.  We just need to make sure pressing HOME from inside the
    Kids app doesn't silently escape — instead it must surface our
    PIN gate.

    How we do that without CATEGORY_HOME:
      1. `onUserLeaveHint()` fires the instant the user presses
         HOME / RECENTS (before the activity is paused).
      2. We immediately schedule a `startActivity(self, REORDER_TO_
         FRONT | SINGLE_TOP)` with an "armed" extra so the activity
         bounces back to the foreground.
      3. On re-foreground we read the extra and pop the PIN overlay
         so the kid must enter the parent PIN before they can keep
         using the device.
      4. `excludeFromRecents` keeps the task off the recents list so
         the recents button can't be used to skip past the PIN.

    The Kids tile in the launcher still launches us directly.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- D-pad / leanback is the primary input — touchscreen optional. -->
    <uses-feature android:name="android.software.leanback" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <application
        android:allowBackup="true"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false"
        android:theme="@style/Theme.OnNowKids"
        android:banner="@mipmap/ic_launcher"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden|layoutDirection|locale"
            android:launchMode="singleTask"
            android:excludeFromRecents="true"
            android:stateNotNeeded="true"
            android:theme="@style/Theme.OnNowKids.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ExoPlayerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|layoutDirection|locale"
            android:launchMode="singleTask"
            android:theme="@style/Theme.OnNowKids" />
    </application>
</manifest>
