<?xml version="1.0" encoding="utf-8"?>
<!--
    ON NOW V2 KIDS — standalone Kids-mode kiosk wrapper.

    The activity is registered as CATEGORY_HOME / CATEGORY_DEFAULT in
    addition to LAUNCHER / LEANBACK_LAUNCHER.  This is the key piece
    that satisfies the user's "MAKE SURE YOU CANT EXIT THE APP BY
    PUSHING THE HOME BUTTON" requirement — the moment Kids mode is
    armed, the user picks our activity as their default launcher (or
    we self-promote on Android 11+) and every subsequent HOME press
    is routed back to MainActivity, which then re-applies the PIN gate
    before letting them out.

    The Vesper TV app no longer carries any Kids-mode wiring (v2.9.2).
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Required to be selectable as the default home / launcher
         app on stock Android — without this the user can't choose
         us in Settings → Default apps → Home app. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- D-pad / leanback is the primary input — touchscreen optional. -->
    <uses-feature android:name="android.software.leanback" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <application
        android:allowBackup="true"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false"
        android:theme="@style/Theme.OnNowKids"
        android:banner="@mipmap/ic_launcher"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden|layoutDirection|locale"
            android:launchMode="singleTask"
            android:stateNotNeeded="true"
            android:theme="@style/Theme.OnNowKids.Splash">
            <!-- Standard launcher entry — appears on the home grid. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
            <!-- HOME intent filter — once selected as the default
                 home app, every HOME button press routes here so the
                 user can't escape Kids without entering the PIN. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Native ExoPlayer surface mirroring the FTA setup —
             launched from `window.OnNowKids.openExoPlayer(...)` so
             the React full-screen player can hand HLS off to a
             native MediaSource for smooth TV playback. -->
        <activity
            android:name=".ExoPlayerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|layoutDirection|locale"
            android:launchMode="singleTask"
            android:theme="@style/Theme.OnNowKids" />
    </application>
</manifest>
