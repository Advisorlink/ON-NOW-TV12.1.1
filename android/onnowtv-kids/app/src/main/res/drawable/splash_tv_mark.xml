<?xml version="1.0" encoding="utf-8"?>
<!--
    ON NOW V2 — Live TV splash mark.

    Big rounded-square enclosing a stylised TV silhouette (screen +
    little antennae).  Tinted white on the splash, the surrounding
    container gets the red gradient via the layer-list at use site.
-->
<vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="220dp"
    android:height="220dp"
    android:viewportWidth="220"
    android:viewportHeight="220">

    <!-- Inner shield (white round-rect with subtle gradient) -->
    <path
        android:pathData="M30,52 L190,52 Q200,52 200,62 L200,170 Q200,180 190,180 L30,180 Q20,180 20,170 L20,62 Q20,52 30,52 Z"
        android:fillColor="#FFFFFFFF" />

    <!-- TV screen (inset, dark for contrast) -->
    <path
        android:pathData="M38,68 L182,68 Q186,68 186,72 L186,160 Q186,164 182,164 L38,164 Q34,164 34,160 L34,72 Q34,68 38,68 Z"
        android:fillColor="#FF2535" />

    <!-- "Play" triangle inside the screen for a TV / video cue -->
    <path
        android:pathData="M96,90 L96,142 L148,116 Z"
        android:fillColor="#FFFFFFFF" />

    <!-- Antennae (top) -->
    <path
        android:pathData="M70,46 L96,18"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="round" />
    <path
        android:pathData="M150,46 L124,18"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="round" />

    <!-- Antenna bulbs -->
    <path
        android:pathData="M92,18 m -7,0 a 7,7 0 1,1 14,0 a 7,7 0 1,1 -14,0"
        android:fillColor="#FFFFFFFF" />
    <path
        android:pathData="M128,18 m -7,0 a 7,7 0 1,1 14,0 a 7,7 0 1,1 -14,0"
        android:fillColor="#FFFFFFFF" />

    <!-- Stand -->
    <path
        android:pathData="M85,180 L135,180 L135,196 L85,196 Z"
        android:fillColor="#FFFFFFFF" />
</vector>
