<?xml version="1.0" encoding="utf-8"?>
<!--
    Rounded-corner mask + thin highlight for the cinematic preview
    poster on the native player's loading screen.  The Kotlin code
    uses clipToOutline + an OutlineProvider for the actual rounded
    corners; this drawable just supplies the dark fallback and the
    inner stroke.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="#11151F" />
            <stroke android:width="1dp" android:color="#33FFFFFF" />
        </shape>
    </item>
</layer-list>
