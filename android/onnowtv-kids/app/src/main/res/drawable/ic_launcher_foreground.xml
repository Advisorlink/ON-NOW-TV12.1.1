<?xml version="1.0" encoding="utf-8"?>
<!--
    Vesper "V" mark — drawn as a stroked path inside the 108x108
    adaptive-icon viewport with the 18-px-per-side safe zone respected.
    Stroke uses the signature neon blue.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer V stroke (neon blue) -->
    <path
        android:strokeColor="#5DC8FF"
        android:strokeWidth="9"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M30,32 L54,80 L78,32" />

    <!-- Subtle inner highlight (lighter blue, thinner) -->
    <path
        android:strokeColor="#A8E3FF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M30,32 L54,80 L78,32" />
</vector>
