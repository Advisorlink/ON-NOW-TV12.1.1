<?xml version="1.0" encoding="utf-8"?>
<!-- Paths the FileProvider is allowed to expose as content:// URIs.
     The Update Gate downloads the APK into the app's external
     cache directory (auto-cleaned by Android), so we only need
     that path here. -->
<paths>
    <external-cache-path
        name="apk_cache"
        path="updates/" />
</paths>
