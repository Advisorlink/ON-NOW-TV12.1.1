<?xml version="1.0" encoding="utf-8"?>
<!-- Poster tile background.
     - default: subtle dark surface
     - focused: cyan glow ring (matches Vesper's `:focus-visible` style)
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/vesper_surface" />
            <corners android:radius="12dp" />
            <stroke android:width="2dp" android:color="@color/vesper_blue" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/vesper_bg_2" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="@color/vesper_line" />
        </shape>
    </item>
</selector>
