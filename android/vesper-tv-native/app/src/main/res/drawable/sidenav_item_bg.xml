<?xml version="1.0" encoding="utf-8"?>
<!-- Side-nav icon button background.
     Matches the Vesper SideNav's pill shape that fades in on focus. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/vesper_surface" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="@color/vesper_blue" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/vesper_bg_2" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="@color/vesper_line" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
