<?xml version="1.0" encoding="utf-8"?>
<!--
    One horizontal shelf row.  Title above, horizontal RecyclerView
    of poster tiles below.  Mirrors Vesper's <Shelf /> React component.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="20dp"
    android:paddingBottom="6dp">

    <TextView
        android:id="@+id/shelf_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginBottom="12dp"
        android:textColor="@color/vesper_text"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="-0.01"
        android:text="" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/shelf_items"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingStart="48dp"
        android:paddingEnd="48dp"
        android:descendantFocusability="afterDescendants"
        android:focusable="false"
        android:overScrollMode="never" />
</LinearLayout>
