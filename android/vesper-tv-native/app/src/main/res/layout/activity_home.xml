<?xml version="1.0" encoding="utf-8"?>
<!--
    VESPER NATIVE — Home screen.

    Layout (mirrors Vesper React Home.jsx):
      [ SIDE NAV 88dp / 240dp (expands on focus) ] [ MAIN ]

    MAIN = vertical RecyclerView (shelves_list) where row 0 is the
    HERO billboard and rows 1…n are horizontal poster rails.  Both
    the side nav and the shelves list are pure RecyclerView so D-pad
    nav uses Android's native focus engine — the buttery-smooth
    experience the user signed off on for V2 Live TV.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/vesper_bg_0">

    <!-- ────────────── SIDE NAV ────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/side_nav"
        android:layout_width="88dp"
        android:layout_height="match_parent"
        android:background="@color/vesper_bg_1"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        android:clipToPadding="false"
        android:descendantFocusability="afterDescendants"
        android:focusable="false"
        android:overScrollMode="never" />

    <!-- ────────────── MAIN CONTENT ────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/shelves_list"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="48dp"
        android:descendantFocusability="afterDescendants"
        android:focusable="false"
        android:overScrollMode="never" />
</LinearLayout>
