<?xml version="1.0" encoding="utf-8"?>
<!-- Full-screen scrim behind the Boost animation — deep navy with
     a subtle vertical hero gradient so the rocket reads as if it
     launched from below. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="90"
        android:startColor="#FF04060B"
        android:centerColor="#FF0C1726"
        android:endColor="#FF050912"
        android:useLevel="false" />
</shape>
