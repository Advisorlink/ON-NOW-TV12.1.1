<?xml version="1.0" encoding="utf-8"?>
<!--
  Focus/state selector for an on-screen keyboard key.  Drives the
  glass→cyan ring focus transition.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true"
        android:drawable="@drawable/onb_key_focused" />
    <item android:state_pressed="true"
        android:drawable="@drawable/onb_key_focused" />
    <item android:drawable="@drawable/onb_key_resting" />
</selector>
