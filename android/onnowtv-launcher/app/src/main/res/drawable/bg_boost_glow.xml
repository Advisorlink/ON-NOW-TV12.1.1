<?xml version="1.0" encoding="utf-8"?>
<!-- Soft radial glow behind the Boost rocket — gradient fades
     from cyan-purple at the centre to transparent at the edges. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="radial"
        android:gradientRadius="320dp"
        android:centerX="0.5"
        android:centerY="0.5"
        android:startColor="#502BB6FF"
        android:centerColor="#28B04CFF"
        android:endColor="#00000000"
        android:useLevel="false" />
</shape>
