<?xml version="1.0" encoding="utf-8"?>
<!--
  Onboarding background — deep inky black with a subtle radial cyan
  glow rising from below.  Matches the Vesper BootSplash aesthetic.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#04060B" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="900dp"
                android:centerX="0.5"
                android:centerY="0.85"
                android:startColor="#262BB6FF"
                android:centerColor="#1410233F"
                android:endColor="#0004060B" />
        </shape>
    </item>
</layer-list>
