<?xml version="1.0" encoding="utf-8"?>
<!--
  v2.10.58 — Boost pill background.  Swapped from the warm
  pink/violet hero gradient to a cool deep-blue → electric-cyan
  gradient at user request ("it needs to be a blue gradient, not
  a pink one").  Sized to match the other top-bar pills (44dp).
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused: brighter inner gradient + white border ring -->
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="9999dp" />
                    <gradient
                        android:type="linear"
                        android:angle="45"
                        android:startColor="#FF1D4ED8"
                        android:centerColor="#FF3B82F6"
                        android:endColor="#FF22D3EE"
                        android:useLevel="false" />
                    <stroke
                        android:width="2dp"
                        android:color="#FFFFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Resting: deeper blue gradient, no border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="9999dp" />
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#FF1E3A8A"
                android:centerColor="#FF2563EB"
                android:endColor="#FF0EA5E9"
                android:useLevel="false" />
        </shape>
    </item>
</selector>
