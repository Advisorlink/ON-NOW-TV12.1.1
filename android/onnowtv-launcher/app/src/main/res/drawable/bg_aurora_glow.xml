<?xml version="1.0" encoding="utf-8"?>
<!-- Soft aurora glow across the top of the stage.  Three layered
     radial gradients (cyan / purple / pink) blurred into one
     atmospheric wash. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="900"
                android:centerX="0.2"
                android:centerY="0.2"
                android:startColor="#332BB6FF"
                android:endColor="#0000B6FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="1100"
                android:centerX="0.8"
                android:centerY="0.1"
                android:startColor="#29BE46FF"
                android:endColor="#00BE46FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="900"
                android:centerX="0.5"
                android:centerY="0.4"
                android:startColor="#1AFF50AA"
                android:endColor="#00FF50AA" />
        </shape>
    </item>
</layer-list>
