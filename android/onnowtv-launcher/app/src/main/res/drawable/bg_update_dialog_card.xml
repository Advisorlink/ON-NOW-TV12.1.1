<?xml version="1.0" encoding="utf-8"?>
<!--
    Themed card background for the pre-update backup dialog.
    Matches the launcher's neon-navy aesthetic:
      • Deep-navy fill (bg_mid).
      • Subtle 1 dp cyan border at brand accent alpha.
      • 20 dp rounded corners so it reads as a card, not a system alert.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
       android:shape="rectangle">
    <corners android:radius="20dp" />
    <solid android:color="#F00A1220" />
    <stroke android:width="1dp" android:color="#552BB6FF" />
</shape>
