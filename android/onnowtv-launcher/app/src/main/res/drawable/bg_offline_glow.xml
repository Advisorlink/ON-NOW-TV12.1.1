<?xml version="1.0" encoding="utf-8"?>
<!-- Soft radial glow behind the offline hero — red-tinted to
     reinforce the "something is wrong" affordance without
     screaming. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="radial"
        android:gradientRadius="320dp"
        android:centerX="0.5"
        android:centerY="0.5"
        android:startColor="#40FF6B6B"
        android:centerColor="#20FF6B6B"
        android:endColor="#00000000"
        android:useLevel="false" />
</shape>
