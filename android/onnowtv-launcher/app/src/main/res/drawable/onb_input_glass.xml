<?xml version="1.0" encoding="utf-8"?>
<!--
  Onboarding input "display" — glass card that shows what the user
  is typing.  NOT an EditText (we own the keyboard) — just a styled
  panel with a TextView inside.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#140B1530" />
    <stroke
        android:width="1dp"
        android:color="#382BB6FF" />
    <corners android:radius="16dp" />
</shape>
