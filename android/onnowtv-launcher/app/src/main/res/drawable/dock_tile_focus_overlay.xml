<?xml version="1.0" encoding="utf-8"?>
<!--
  v0.6 — Foreground state-list for dock tiles.

  This drawable lives on the OUTER FrameLayout's `foreground`
  slot in item_dock.xml so it paints ON TOP of the image and
  only when the tile owns D-pad / touch focus.

  Resting state is a fully-transparent placeholder so the
  uploaded image is the entire visual statement of the tile.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true"  android:drawable="@drawable/dock_tile_focused" />
    <item android:state_selected="true" android:drawable="@drawable/dock_tile_focused" />
    <item android:state_pressed="true"  android:drawable="@drawable/dock_tile_focused" />
    <item                                android:drawable="@android:color/transparent" />
</selector>
