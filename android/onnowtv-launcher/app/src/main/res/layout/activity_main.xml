<?xml version="1.0" encoding="utf-8"?>
<!--
  v0.5 — Stripped-down launcher.  Wallpaper + topbar + dock only.
  Removed: aurora glow, hero illustration, paginator, featured
  content column (title / tagline / description / CTA).  Per-tile
  wallpaper is now the entire visual statement of the screen.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="@color/bg_deep">

    <!-- Per-tile wallpaper.  Edge-to-edge, painted before everything
         else.  Hidden when the focused tile has no wallpaper. -->
    <ImageView
        android:id="@+id/tile_wallpaper"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="@null"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom darkening gradient so dock + reflection read cleanly
         over any wallpaper. v0.7 — bumped to 340 dp to cover the new
         taller dock (254) + bottom margin (20) + breathing room. -->
    <View
        android:id="@+id/tile_wallpaper_scrim"
        android:layout_width="0dp"
        android:layout_height="340dp"
        android:background="@drawable/bg_dock_scrim"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Debug status pill (top-right).  Auto-hides on first OK. -->
    <TextView
        android:id="@+id/debug_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="6dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:background="@drawable/bg_debug_pill"
        android:textColor="#FFD700"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:maxWidth="600dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:elevation="20dp"
        app:layout_constraintTop_toBottomOf="@id/topbar"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="connecting…" />

    <!-- Top bar (greeting / logo / date / time). -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="@drawable/bg_topbar"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_wifi"
                android:tint="@color/text_primary"
                android:contentDescription="@null" />
            <TextView
                android:id="@+id/greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                tools:text="Good evening" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_play_solid"
                android:tint="@color/accent"
                android:contentDescription="@null" />
            <TextView
                android:id="@+id/logoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/wordmark"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="end|center_vertical">
            <TextView
                android:id="@+id/dateLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                tools:text="Friday · 12 Jul" />
            <View
                android:layout_width="1dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="14dp"
                android:background="@color/border" />
            <TextView
                android:id="@+id/timeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                tools:text="20:42" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom dock — variable number of tiles (1..N).
         v0.9 — Sits right against the bottom edge of the screen.
         Bottom margin = 0, paddingBottom trimmed to 4 dp (just
         enough headroom for the focused tile's halo while keeping
         the reflection visually near the floor). -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/dock"
        android:layout_width="0dp"
        android:layout_height="268dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="0dp"
        android:paddingTop="22dp"
        android:paddingBottom="4dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:descendantFocusability="afterDescendants"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
