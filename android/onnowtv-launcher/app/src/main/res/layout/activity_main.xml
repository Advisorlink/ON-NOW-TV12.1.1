<?xml version="1.0" encoding="utf-8"?>
<!--
  v0.5 — Stripped-down launcher.  Wallpaper + topbar + dock only.
  Removed: aurora glow, hero illustration, paginator, featured
  content column (title / tagline / description / CTA).  Per-tile
  wallpaper is now the entire visual statement of the screen.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="@color/bg_deep">

    <!-- Per-tile wallpaper.  Edge-to-edge, painted before everything
         else.  Hidden when the focused tile has no wallpaper. -->
    <ImageView
        android:id="@+id/tile_wallpaper"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="@null"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom darkening gradient so dock + reflection read cleanly
         over any wallpaper. v0.7 — bumped to 340 dp to cover the new
         taller dock (254) + bottom margin (20) + breathing room. -->
    <View
        android:id="@+id/tile_wallpaper_scrim"
        android:layout_width="0dp"
        android:layout_height="340dp"
        android:background="@drawable/bg_dock_scrim"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Debug status pill (top-right).  Auto-hides on first OK. -->
    <TextView
        android:id="@+id/debug_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="6dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:background="@drawable/bg_debug_pill"
        android:textColor="#FFD700"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:maxWidth="600dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:elevation="20dp"
        app:layout_constraintTop_toBottomOf="@id/topbar"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="connecting…" />

    <!-- v2.8.19 — Top bar redesigned: glass card with focusable
         VPN + Speed Test pill buttons (left), polished logo
         centred, animated clock on the right.  Pressing UP from
         the dock now focuses the leftmost pill (wired via
         nextFocusUp* on the dock items).  Height bumped from
         56→72dp to give the pills + clock proper breathing room. -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="22dp"
        android:background="@drawable/bg_topbar"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:clipChildren="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- LEFT slot: action pills.  v2.8.52 — Order is now
             V2 AI (hero) → VPN → Speed Test so the hero pill grabs
             attention first.  D-pad focus chain follows the same
             left-to-right order. -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="start|center_vertical"
            android:clipChildren="false">

            <!-- v2.8.23 — V2 AI push-and-hold voice assistant.
                 v2.8.49 — "Hero" pill — much bigger than the others by
                 default (64 dp tall) with a multi-stop cyan→magenta→
                 violet gradient, so it visually screams "use me".
                 v2.8.52 — Moved to the FIRST position in the top bar.
                 Admin can override height/width via the V2 AI tab. -->
            <LinearLayout
                android:id="@+id/topbar_btn_v2ai"
                android:layout_width="wrap_content"
                android:layout_height="64dp"
                android:minWidth="148dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="26dp"
                android:background="@drawable/bg_topbar_btn_v2ai"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:clickable="true"
                android:elevation="6dp"
                android:nextFocusDown="@id/dock"
                android:nextFocusRight="@id/topbar_btn_boost">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_v2ai_sparkle"
                    android:tint="#FFFFFFFF"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:textColor="#FFFFFFFF"
                    android:textSize="18sp"
                    android:letterSpacing="0.16"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:shadowColor="#A6000814"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="6"
                    android:text="V2 AI" />
            </LinearLayout>

            <!-- v2.10.45 — BOOST pill (RAM cleaner).  Sits right
                 next to the V2 AI pill so the two hero actions are
                 visually paired.
                 v2.10.58 — User requested same size as the other
                 pills (VPN / Speed Test) and a blue gradient
                 instead of the pink one.  Height dropped 64dp →
                 44dp, padding tightened, icon shrunk to match. -->
            <LinearLayout
                android:id="@+id/topbar_btn_boost"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:background="@drawable/bg_topbar_btn_boost"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:clickable="true"
                android:nextFocusDown="@id/dock"
                android:nextFocusLeft="@id/topbar_btn_v2ai"
                android:nextFocusRight="@id/topbar_btn_vpn">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_boost_rocket"
                    android:tint="#FFFFFFFF"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp"
                    android:letterSpacing="0.14"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:text="BOOST" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/topbar_btn_vpn"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:background="@drawable/bg_topbar_btn"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:clickable="true"
                android:nextFocusDown="@id/dock"
                android:nextFocusLeft="@id/topbar_btn_boost"
                android:nextFocusRight="@id/topbar_btn_speed">

                <ImageView
                    android:id="@+id/topbar_vpn_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_vpn_shield"
                    android:tint="@color/text_primary"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/topbar_vpn_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="9dp"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:letterSpacing="0.06"
                    android:fontFamily="sans-serif-medium"
                    android:text="VPN" />

                <!-- Tiny status dot (green when VPN connected). -->
                <View
                    android:id="@+id/topbar_vpn_dot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_status_dot_off" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/topbar_btn_speed"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:background="@drawable/bg_topbar_btn"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:clickable="true"
                android:nextFocusDown="@id/dock"
                android:nextFocusLeft="@id/topbar_btn_vpn">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_speed_gauge"
                    android:tint="@color/text_primary"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="9dp"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:letterSpacing="0.06"
                    android:fontFamily="sans-serif-medium"
                    android:text="Speed Test" />
            </LinearLayout>
        </LinearLayout>

        <!-- CENTRE: polished logo block.  Play glyph in accent
             gradient + wordmark with V2 highlighted. -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_logo_play">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_play_solid"
                    android:tint="#04060B"
                    android:contentDescription="@null" />
            </FrameLayout>
            <TextView
                android:id="@+id/logoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/wordmark"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:letterSpacing="0.18"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- RIGHT slot: WiFi indicator + date + time.
             v2.10.45 — Removed the time-of-day greeting per user
             demand ("take away the good evening/good morning").
             The slot now leads with a WiFi-state icon that ticks
             between full / weak / off based on
             ConnectivityManager + signal-strength callbacks.  The
             icon is FOCUSABLE so the user can press OK to open
             the system Wi-Fi settings (Settings.ACTION_WIFI_SETTINGS). -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="end|center_vertical">

            <ImageView
                android:id="@+id/wifiIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="14dp"
                android:padding="6dp"
                android:src="@drawable/ic_wifi"
                android:tint="@color/text_primary"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:clickable="true"
                android:background="@drawable/bg_topbar_btn"
                android:contentDescription="Wi-Fi status" />

            <TextView
                android:id="@+id/dateLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                tools:text="Friday · 12 Jul" />
            <View
                android:layout_width="1dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="14dp"
                android:background="@color/border" />
            <TextView
                android:id="@+id/timeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                tools:text="20:42" />

            <!-- v2.10.45 — Greeting TextView kept in the tree but
                 hidden, so any code still referencing
                 `binding.greeting` keeps compiling.  Width/height
                 collapse to 0 since visibility=gone. -->
            <TextView
                android:id="@+id/greeting"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                tools:text="Good evening" />
        </LinearLayout>
    </LinearLayout>

    <!-- Featured panel — heading / description / CTA pill overlaid
         on the wallpaper.  Anchored to the LEFT half of the screen
         so it never collides with the dock below.  Populated +
         tinted by MainActivity.applyFeaturedPanel() whenever the
         focused dock tile changes.  alpha starts at 0 — fades in
         after the first config loads. -->
    <LinearLayout
        android:id="@+id/featured_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginBottom="36dp"
        android:alpha="0"
        app:layout_constraintWidth_max="820dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/featured_panel_spacer"
        app:layout_constraintBottom_toTopOf="@id/dock"
        app:layout_constraintHorizontal_bias="0.0">

        <!-- v1.6 — Heading-as-image (optional).  Hidden by default;
             MainActivity flips visibility when the admin sets
             `featured_heading_image_url` in the Layout Editor.
             When visible, the text heading is hidden. -->
        <ImageView
            android:id="@+id/featured_heading_image"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:adjustViewBounds="true"
            android:scaleType="fitStart"
            android:contentDescription="@null"
            android:visibility="gone"
            tools:src="@drawable/ic_launcher_foreground"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/featured_heading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat"
            android:textSize="56sp"
            android:textColor="#FFFFFF"
            android:shadowColor="#A6000814"
            android:shadowDx="0"
            android:shadowDy="4"
            android:shadowRadius="16"
            android:letterSpacing="-0.01"
            android:singleLine="false"
            android:maxLines="999"
            android:ellipsize="none"
            tools:text="Movies" />

        <TextView
            android:id="@+id/featured_subheading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/montserrat"
            android:textSize="22sp"
            android:textColor="#F0F4FA"
            android:shadowColor="#A6000814"
            android:shadowDx="0"
            android:shadowDy="3"
            android:shadowRadius="12"
            android:letterSpacing="0.02"
            android:maxWidth="640dp"
            android:singleLine="false"
            android:maxLines="999"
            android:ellipsize="none"
            android:visibility="gone"
            tools:text="On demand · 4K HDR"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/featured_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/montserrat"
            android:textSize="17sp"
            android:textColor="#D8E2EF"
            android:shadowColor="#A6000814"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="10"
            android:lineSpacingExtra="3sp"
            android:maxWidth="640dp"
            android:singleLine="false"
            android:maxLines="999"
            android:ellipsize="none"
            android:breakStrategy="high_quality"
            tools:text="Stream the latest blockbusters, hidden gems and indie favourites in 4K HDR." />

        <FrameLayout
            android:id="@+id/featured_cta_wrap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp">

            <TextView
                android:id="@+id/featured_cta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="28dp"
                android:paddingVertical="13dp"
                android:background="@drawable/bg_cta_pill"
                android:fontFamily="@font/montserrat"
                android:textSize="13sp"
                android:textColor="#04060B"
                android:letterSpacing="0.18"
                android:text="ENTER"
                tools:text="ENTER" />
        </FrameLayout>
    </LinearLayout>

    <!-- Invisible spacer that the featured panel's end-constraint
         anchors against.  Keeps the heading/description column from
         growing wider than ~52 % of the screen so it never overlaps
         the dock on the right side of the screen. -->
    <View
        android:id="@+id/featured_panel_spacer"
        android:layout_width="0dp"
        android:layout_height="1dp"
        app:layout_constraintWidth_percent="0.48"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- v2.8.24 — QR Video overlay panel.  Floats over the wallpaper
         in the upper-right corner of the home screen, ABOVE the dock.
         Shows the QR image + title + caption for the currently-
         featured QR video.  When the admin has multiple visible QRs,
         MainActivity cycles through them every 8 s.  Entire panel is
         hidden (visibility=GONE) when no visible QR videos exist. -->
    <LinearLayout
        android:id="@+id/qr_video_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:gravity="center_horizontal"
        android:background="@drawable/qr_panel_bg"
        android:visibility="gone"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/qr_video_eyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SCAN TO WATCH"
            android:textColor="#FF2BB6FF"
            android:textSize="10sp"
            android:letterSpacing="0.22"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <ImageView
            android:id="@+id/qr_video_image"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:background="@android:color/white"
            android:padding="4dp"
            android:contentDescription="QR code" />

        <TextView
            android:id="@+id/qr_video_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#FFF4F7FB"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:maxWidth="190dp" />

        <TextView
            android:id="@+id/qr_video_caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#FF8EA0B7"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:maxWidth="190dp"
            android:gravity="center_horizontal" />
    </LinearLayout>

    <!-- Bottom dock — variable number of tiles (1..N).
         v0.9.1 — Pushed past the screen edge with a NEGATIVE
         marginBottom so tiles + reflection ride right against the
         floor.  paddingTop retained for halo headroom. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/dock"
        android:layout_width="0dp"
        android:layout_height="268dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="-16dp"
        android:paddingTop="22dp"
        android:paddingBottom="4dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:descendantFocusability="afterDescendants"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- v2.10.45 — Boost overlay (RAM cleaner animation).  Sits as
         a sibling at the very end of the ConstraintLayout so it
         paints ON TOP of every other view including the topbar
         and dock.  Visibility flipped from `gone` → `visible` +
         alpha-animated by MainActivity.performBoost().  See
         overlay_boost.xml for the inner structure.

         NOTE: NO `android:id` on this <include> tag — when you
         set one, it replaces the included root view's own id,
         which would break our findViewById(R.id.boost_overlay)
         lookups in MainActivity. -->
    <include
        layout="@layout/overlay_boost"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- v2.10.45 — Offline overlay.  Sits below the Boost overlay
         in the z-order (Boost is drawn last and thus on top) so a
         user-initiated Boost can still be triggered if the box is
         offline.  Visibility flipped by MainActivity's network
         callback. -->
    <include
        layout="@layout/overlay_offline"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
