<?xml version="1.0" encoding="utf-8"?>
<!--
  Activity layout for the launcher home screen.

  The whole hierarchy is sized for an exact 1920x1080 Android TV
  panel.  Every dimension uses dp so smaller dev devices (e.g. a
  1280x720 emulator) just downscale proportionally.

  Z-order (back → front):
    1. Aurora glow background    @id/aurora_glow
    2. Hero illustration         @id/hero_illustration  (right pane)
    3. Featured content column   @id/content_column     (left pane)
    4. Top status bar            @id/topbar
    5. Vertical paginator        @id/paginator
    6. Bottom dock RecyclerView  @id/dock
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <!-- Aurora glow at the top (Variation 1 from the mockup set). -->
    <View
        android:id="@+id/aurora_glow"
        android:layout_width="0dp"
        android:layout_height="600dp"
        android:background="@drawable/bg_aurora_glow"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Hero illustration on the right.  Programmatic Canvas
         drawing in HeroIllustration.kt. -->
    <tv.onnow.launcher.HeroIllustration
        android:id="@+id/hero_illustration"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/dock"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/paginator"
        app:layout_constraintHorizontal_bias="1.0"
        android:layout_marginTop="64dp"
        android:layout_marginBottom="20dp"
        android:layout_marginEnd="0dp"
        app:layout_constraintWidth_percent="0.55" />

    <!-- Top status bar (greeting / logo / date / time). -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="@drawable/bg_topbar"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Left: WiFi icon + greeting -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_wifi"
                android:tint="@color/text_primary"
                android:contentDescription="@null" />
            <TextView
                android:id="@+id/greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                tools:text="Good evening" />
        </LinearLayout>

        <!-- Center: Play-icon + OnNow TV V2 wordmark -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <View
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_logo_play" />
            <TextView
                android:id="@+id/logoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                tools:text="OnNow TV V2" />
        </LinearLayout>

        <!-- Right: date + divider + time -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical|end">
            <TextView
                android:id="@+id/dateLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                tools:text="Sunday, May 17" />
            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:background="@color/divider"
                android:layout_marginHorizontal="16dp" />
            <TextView
                android:id="@+id/timeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                tools:text="08:34 PM" />
        </LinearLayout>
    </LinearLayout>

    <!-- Vertical paginator (4 dots, 1 active segment). -->
    <LinearLayout
        android:id="@+id/paginator"
        android:layout_width="20dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="48dp"
        app:layout_constraintTop_toBottomOf="@id/topbar"
        app:layout_constraintBottom_toTopOf="@id/dock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintVertical_bias="0.18">

        <View
            android:id="@+id/paginatorActive"
            android:layout_width="3dp"
            android:layout_height="42dp"
            android:layout_marginBottom="18dp"
            android:background="@color/accent" />
        <View
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_paginator_dot" />
        <View
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_paginator_dot" />
        <View
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:background="@drawable/bg_paginator_dot" />
    </LinearLayout>

    <!-- Featured content column on the left. -->
    <LinearLayout
        android:id="@+id/content_column"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="104dp"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/topbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_percent="0.40">

        <TextView
            android:id="@+id/kicker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/featured"
            android:textColor="@color/accent"
            android:textSize="11sp"
            android:letterSpacing="0.4"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">
            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="64sp"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold"
                android:lineSpacingExtra="-6dp"
                tools:text="Live TV." />
            <!-- The "glow" rectangle behind the title's period — its
                 background colour is updated programmatically and
                 acts as a soft accent square underneath the dot. -->
            <View
                android:id="@+id/titlePeriodGlow"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            tools:text="Real-time channels. Real moments." />

        <TextView
            android:id="@+id/description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.55"
            tools:text="Watch live news, sports, and entertainment as it happens. Stay connected to the world in real time." />

        <!-- "Explore what's new" CTA pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="14dp"
            android:background="@drawable/bg_cta">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/explore_whats_new"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="14dp"
                android:src="@drawable/ic_arrow_right"
                android:tint="@color/text_primary"
                android:contentDescription="@null" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom 6-tile dock. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/dock"
        android:layout_width="0dp"
        android:layout_height="124dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="24dp"
        android:clipToPadding="false"
        android:paddingHorizontal="0dp"
        android:descendantFocusability="afterDescendants"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
