<?xml version="1.0" encoding="utf-8"?>
<!--
  One bottom-dock tile.  Drawn N times via RecyclerView (variable
  tile count, 1..N driven by the admin backend).

  The root LinearLayout is the focus owner — its background is a
  state-list drawable (dock_tile_bg) that swaps in the neon outline
  + glow when state_focused="true".

  v0.5 — Fixed tile width (260dp) instead of weight-distributed.
  RecyclerView does NOT honour layout_weight, so 0dp+weight made
  tiles render as 0px wide.  Fixed width with horizontal scroll
  works for any tile count.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="260dp"
    android:layout_height="match_parent"
    android:layout_marginHorizontal="6dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="20dp"
    android:background="@drawable/dock_tile_bg"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:clickable="true">

    <ImageView
        android:id="@+id/icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:tint="@color/text_primary"
        android:contentDescription="@null"
        tools:src="@drawable/ic_dock_tv" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Live TV" />

        <TextView
            android:id="@+id/sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Watch live channels" />
    </LinearLayout>
</LinearLayout>
