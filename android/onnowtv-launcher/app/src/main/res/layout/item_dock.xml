<?xml version="1.0" encoding="utf-8"?>
<!--
  v0.6 — Image-only dock tile.

  STRUCTURE
  ─────────
  The tile is two nested FrameLayouts:

  * `tile_root`   (outer)  ─ focus owner.  Does NOT clip its
                             children, so the focused-state
                             foreground drawable can paint a
                             halo that EXTENDS beyond the tile
                             rectangle (negative-inset strokes
                             in `dock_tile_focused.xml`).

  * `tile_clip`   (inner)  ─ rounded background drawable provides
                             a smoothly-rounded outline, and
                             `clipToOutline="true"` clips the
                             child ImageView to that outline.

  No labels, no sub-text — the JPEG that the admin uploads IS the
  tile.  The admin can bake the title into the image itself.

  The outer marginVertical leaves 20 dp top/bottom inside the
  RecyclerView (which has `clipChildren="false"`) so the focused
  halo (~6 dp outside the tile rectangle) is never clipped.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tile_root"
    android:layout_width="320dp"
    android:layout_height="180dp"
    android:layout_marginHorizontal="10dp"
    android:clipChildren="false"
    android:foreground="@drawable/dock_tile_focus_overlay"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:clickable="true">

    <!-- Inner: rounded clip surface that holds the image. -->
    <FrameLayout
        android:id="@+id/tile_clip"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/dock_tile_resting"
        android:clipToOutline="true">

        <ImageView
            android:id="@+id/icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null"
            tools:src="@drawable/ic_dock_tv" />

    </FrameLayout>

</FrameLayout>
