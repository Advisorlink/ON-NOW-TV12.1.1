<?xml version="1.0" encoding="utf-8"?>
<!--
  v2.10.59 — Image-only dock tile + per-tile UPDATE pill.

  STRUCTURE
  ─────────
  Outer FrameLayout (`tile_outer`) so the update pill can float
  ABOVE the tile via negative translationY without affecting the
  dock's vertical baseline.  `clipChildren=false` is critical at
  EVERY level up to the RecyclerView so the pill (and the focus
  halo) can render outside their own bounds.

  • `tile_outer`    — FrameLayout, no clipping.  Houses the vertical
                      content stack at the BOTTOM and the floating
                      pill anchored to the TOP.
  • `tile_root`     — focus owner for the tile itself.  Inner
                      `tile_clip` carries the rounded background +
                      clipToOutline that crops the ImageView.
  • `reflection_clip` — floor reflection (mirrored copy of icon).
  • `update_pill`   — focusable pill rendered above the tile when
                      the per-tile APK pin differs from what's
                      installed.  Defaults to GONE so layout
                      collapses back to the original height when
                      no update is pending.  Visibility + label
                      driven by DockAdapter.

  No labels on the tile itself — admin bakes any title text into
  the JPEG.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tile_outer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- ────────── Tile + reflection (vertical stack) ────────── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:clipChildren="false">

        <!-- Main tile (focus owner + halo) -->
        <FrameLayout
            android:id="@+id/tile_root"
            android:layout_width="300dp"
            android:layout_height="168dp"
            android:layout_marginHorizontal="10dp"
            android:clipChildren="false"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:clickable="true">

            <FrameLayout
                android:id="@+id/tile_clip"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/dock_tile_resting"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@null"
                    tools:src="@drawable/ic_dock_tv" />
            </FrameLayout>
        </FrameLayout>

        <!-- Floor reflection (mirrored copy of the image, fades into bg) -->
        <FrameLayout
            android:id="@+id/reflection_clip"
            android:layout_width="300dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/dock_reflection_clip"
            android:clipToOutline="true">

            <ImageView
                android:id="@+id/reflection"
                android:layout_width="match_parent"
                android:layout_height="168dp"
                android:layout_gravity="top"
                android:scaleType="centerCrop"
                android:scaleY="-1"
                android:alpha="0.30"
                android:contentDescription="@null" />

            <View
                android:id="@+id/reflection_fade"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/dock_reflection_fade" />
        </FrameLayout>
    </LinearLayout>

    <!-- ────────── Floating UPDATE pill ────────── -->
    <!-- v2.10.70 — Bumped translationY from -30dp to -42dp so the
         pill sits noticeably HIGHER above the tile.  User report:
         *"just move that Update button, just up just a little tiny
         bit more"*.  Still anchored top|center_horizontal so it
         stays visually centered over the tile artwork. -->
    <!-- v2.10.66 — Pure VISUAL BADGE.  The pill is no longer
         focusable; the tile click itself triggers the install/
         update when there's one pending.  Picked up by
         DockAdapter.bindUpdatePill — visibility GONE by default
         so layout collapses cleanly when no update pending. -->
    <TextView
        android:id="@+id/update_pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:translationY="-42dp"
        android:visibility="gone"
        android:paddingHorizontal="22dp"
        android:paddingVertical="8dp"
        android:textSize="13sp"
        android:textColor="#FFFFFFFF"
        android:textStyle="bold"
        android:letterSpacing="0.14"
        android:elevation="8dp"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:clickable="false"
        android:duplicateParentState="false"
        android:contentDescription="Update available — press this tile to install"
        tools:text="↻ UPDATE · v2.10.65"
        tools:visibility="visible" />

</FrameLayout>
