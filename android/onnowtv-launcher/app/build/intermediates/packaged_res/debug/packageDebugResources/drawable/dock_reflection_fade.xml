<?xml version="1.0" encoding="utf-8"?>
<!--
  Vertical fade mask for the floor reflection.

  Painted ON TOP of the upside-down image:
    • Top  (right under the tile)  → fully transparent
                                     so the reflection reads clearly
    • Bottom (further from the tile) → solid bg_deep
                                     so the reflection dies into
                                     the launcher background

  Combined with the 0.30 alpha on the reflection ImageView itself,
  this gives a believable polished-floor reflection that fades out
  with distance from the object — without needing any code.

  Angle reference (Android GradientDrawable):
    0°   = left → right
    90°  = bottom → top
    180° = right → left
    270° = top → bottom   ← what we want
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#0004060B"
        android:endColor="#FF04060B" />
</shape>
