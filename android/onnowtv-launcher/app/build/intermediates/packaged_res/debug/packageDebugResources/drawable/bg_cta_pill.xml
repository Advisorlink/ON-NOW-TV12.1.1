<?xml version="1.0" encoding="utf-8"?>
<!--
  v0.9 — Featured CTA pill background.

  Solid rounded rectangle.  The pill's fill colour is set at runtime
  by MainActivity.applyFeaturedPanel() so it matches the focused
  tile's accent colour.  Stroke + corner radius defined here so the
  geometry stays consistent regardless of colour.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#2BB6FF" />
    <corners android:radius="22dp" />
</shape>
