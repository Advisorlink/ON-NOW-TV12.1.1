<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.OnNowTunes" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/tunes_bg</item>
        <item name="android:statusBarColor">@color/tunes_bg</item>
        <item name="android:navigationBarColor">@color/tunes_bg</item>
        <item name="colorPrimary">@color/tunes_accent</item>
        <item name="colorPrimaryDark">@color/tunes_bg_dark</item>
        <item name="colorAccent">@color/tunes_accent</item>
    </style>
    <style name="Theme.OnNowTunes.NoActionBar" parent="Theme.OnNowTunes">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>
