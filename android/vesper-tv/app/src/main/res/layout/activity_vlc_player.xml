<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <!-- VLC video surface -->
    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/video_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ============================================================
         CINEMATIC PREVIEW OVERLAY  (loading screen)
         ============================================================ -->
    <FrameLayout
        android:id="@+id/preview_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#06080F">

        <ImageView
            android:id="@+id/preview_backdrop"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:alpha="0.55"
            android:contentDescription="@null" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/preview_vignette" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="80dp"
            android:paddingEnd="80dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/preview_poster"
                android:layout_width="220dp"
                android:layout_height="330dp"
                android:layout_marginEnd="48dp"
                android:scaleType="centerCrop"
                android:background="@drawable/poster_bg"
                android:clipToOutline="true"
                android:elevation="24dp"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/preview_eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOW PLAYING · ON NOW TV V2"
                    android:textColor="#5DC8FF"
                    android:textSize="12sp"
                    android:letterSpacing="0.22"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:id="@+id/preview_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.0"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/preview_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#A8B5C7"
                    android:textSize="15sp"
                    android:layout_marginTop="14dp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/preview_synopsis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#C7CFDB"
                    android:textSize="15sp"
                    android:lineSpacingMultiplier="1.45"
                    android:layout_marginTop="18dp"
                    android:maxLines="3"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/preview_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ON NOW TV V2 is loading your program"
                    android:textColor="#5DC8FF"
                    android:textSize="13sp"
                    android:letterSpacing="0.16"
                    android:fontFamily="monospace"
                    android:layout_marginTop="28dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:background="@drawable/status_pill" />

                <TextView
                    android:id="@+id/preview_loading_dots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●  ●  ●"
                    android:textColor="#5DC8FF"
                    android:textSize="14sp"
                    android:letterSpacing="0.6"
                    android:fontFamily="monospace"
                    android:layout_marginTop="14dp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:id="@+id/preview_shimmer"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_gravity="bottom"
            android:background="#5DC8FF" />
    </FrameLayout>

    <!-- ============================================================
         BUFFERING SPINNER (during playback only)
         ============================================================ -->
    <ProgressBar
        android:id="@+id/loading_view"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:indeterminate="true"
        android:indeterminateTint="#5DC8FF"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ============================================================
         SKIP INTRO PILL (bottom-right, TV shows only)
         ============================================================ -->
    <Button
        android:id="@+id/btn_skip_intro"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_marginEnd="48dp"
        android:layout_marginBottom="180dp"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:text="Skip Intro"
        android:textAllCaps="false"
        android:textColor="#000000"
        android:textSize="17sp"
        android:textStyle="bold"
        android:background="@drawable/btn_skip_intro"
        android:visibility="gone"
        android:elevation="20dp"
        android:focusable="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- ============================================================
         CONTROLS OVERLAY
         ============================================================ -->
    <FrameLayout
        android:id="@+id/controls_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Full-screen scrim so the buttons stay legible even over
             very bright scenes (sky shots, white backgrounds, etc.) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000" />

        <!-- Top gradient -->
        <View
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/grad_top"
            android:layout_gravity="top" />

        <!-- Bottom gradient -->
        <View
            android:layout_width="match_parent"
            android:layout_height="340dp"
            android:background="@drawable/grad_bottom"
            android:layout_gravity="bottom" />

        <!-- Centre vignette so the play/skip buttons stay readable -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/grad_center_dim" />

        <!-- ─── Top row: back + title ──────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="32dp"
            android:paddingTop="28dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/btn_glass_circle"
                android:contentDescription="Back"
                android:padding="14dp"
                android:src="@drawable/ic_back"
                android:focusable="true"
                android:nextFocusDown="@id/btn_play_pause" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOW PLAYING"
                    android:textColor="#5DC8FF"
                    android:textSize="11sp"
                    android:letterSpacing="0.22"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ─── CENTRE: skip back / play / skip fwd ────────────── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_skip_back"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/btn_glass_circle"
                android:contentDescription="Skip back 10 seconds"
                android:padding="22dp"
                android:src="@drawable/ic_replay_10"
                android:focusable="true"
                android:nextFocusLeft="@id/btn_back"
                android:nextFocusRight="@id/btn_play_pause"
                android:nextFocusDown="@id/btn_subs" />

            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:layout_marginStart="32dp"
                android:layout_marginEnd="32dp"
                android:background="@drawable/btn_round"
                android:contentDescription="Play / Pause"
                android:padding="28dp"
                android:src="@drawable/ic_pause"
                android:elevation="6dp"
                android:focusable="true"
                android:nextFocusLeft="@id/btn_skip_back"
                android:nextFocusRight="@id/btn_skip_fwd"
                android:nextFocusUp="@id/btn_back"
                android:nextFocusDown="@id/btn_audio" />

            <ImageButton
                android:id="@+id/btn_skip_fwd"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/btn_glass_circle"
                android:contentDescription="Skip forward 10 seconds"
                android:padding="22dp"
                android:src="@drawable/ic_forward_10"
                android:focusable="true"
                android:nextFocusLeft="@id/btn_play_pause"
                android:nextFocusRight="@id/btn_skip_intro"
                android:nextFocusDown="@id/btn_speed" />
        </LinearLayout>

        <!-- ─── BOTTOM: seek bar + time + settings row ─────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingHorizontal="40dp"
            android:paddingBottom="40dp">

            <!-- Seek bar with inline time labels -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tv_position"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:minWidth="56dp" />

                <SeekBar
                    android:id="@+id/seek_bar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="14dp"
                    android:layout_weight="1"
                    android:focusable="true"
                    android:progressTint="#5DC8FF"
                    android:thumbTint="#5DC8FF"
                    android:progressBackgroundTint="#33FFFFFF"
                    android:maxHeight="3dp" />

                <TextView
                    android:id="@+id/tv_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:minWidth="56dp"
                    android:gravity="end" />
            </LinearLayout>

            <!-- Settings row: subtitles / audio / speed / aspect -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_subs"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/btn_pill"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"
                    android:drawableStart="@drawable/ic_subtitles"
                    android:drawablePadding="10dp"
                    android:text="Subtitles"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:focusable="true"
                    android:nextFocusUp="@id/btn_skip_back"
                    android:nextFocusRight="@id/btn_audio" />

                <Button
                    android:id="@+id/btn_audio"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/btn_pill"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"
                    android:drawableStart="@drawable/ic_audio"
                    android:drawablePadding="10dp"
                    android:text="Audio"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:focusable="true"
                    android:nextFocusUp="@id/btn_play_pause"
                    android:nextFocusLeft="@id/btn_subs"
                    android:nextFocusRight="@id/btn_speed" />

                <Button
                    android:id="@+id/btn_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/btn_pill"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"
                    android:drawableStart="@drawable/ic_speed"
                    android:drawablePadding="10dp"
                    android:text="Speed"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:focusable="true"
                    android:nextFocusUp="@id/btn_skip_fwd"
                    android:nextFocusLeft="@id/btn_audio"
                    android:nextFocusRight="@id/btn_aspect" />

                <Button
                    android:id="@+id/btn_aspect"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:background="@drawable/btn_pill"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"
                    android:drawableStart="@drawable/ic_aspect"
                    android:drawablePadding="10dp"
                    android:text="Aspect"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:focusable="true"
                    android:nextFocusUp="@id/btn_skip_fwd"
                    android:nextFocusLeft="@id/btn_speed"
                    android:nextFocusRight="@id/btn_channels" />

                <Button
                    android:id="@+id/btn_channels"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/btn_pill_accent"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"
                    android:drawableStart="@drawable/ic_grid"
                    android:drawablePadding="10dp"
                    android:text="Channels"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:focusable="true"
                    android:visibility="gone"
                    android:nextFocusUp="@id/btn_skip_fwd"
                    android:nextFocusLeft="@id/btn_aspect" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- ============================================================
         TRACK PICKER SHEET (Subtitles / Audio / Speed / Aspect)
         ============================================================ -->
    <FrameLayout
        android:id="@+id/picker_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#A6000000"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="460dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:background="#F00A0E18"
            android:orientation="vertical"
            android:paddingTop="44dp"
            android:paddingBottom="36dp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp">

            <TextView
                android:id="@+id/picker_eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SETTINGS"
                android:textColor="#5DC8FF"
                android:textSize="11sp"
                android:letterSpacing="0.22"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/picker_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:text="Subtitles"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/picker_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scrollbars="vertical" />

            <Button
                android:id="@+id/picker_close"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/btn_pill"
                android:text="Close"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- ============================================================
         LIVE GUIDE OVERLAY — premium edge-panel design
         ============================================================
         REDESIGNED v2.6.2.  The previous full-screen guide covered
         the video; this one slides in from the LEFT as a 460dp-wide
         vertical panel so the player stays fully visible to the
         right.  The currently-focused channel renders a programme
         detail card that overlays the player's bottom-right corner
         with poster + title + Now/Next.

         Two animated parts:
           • guide_panel  – slides in/out (translateX from -460dp → 0)
           • guide_detail – fades in/out as focus moves (alpha 0 → 1)

         No traditional player buttons inside the guide — the user's
         brief was "premium, no buttons, channel + cover art the
         star".  D-pad up/down to scroll, OK to switch channel, BACK
         to dismiss.
         ============================================================ -->
    <FrameLayout
        android:id="@+id/guide_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clipChildren="false">

        <!-- Soft scrim under the right edge of the panel so the
             panel's drop shadow looks lifted off the video.  4 dp
             gradient with no blur (HK1's Chrome 52 can't handle a
             real backdrop-filter without dropping frames). -->
        <View
            android:id="@+id/guide_scrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/guide_scrim_gradient" />

        <!-- LEFT panel — vertical channel list + header.  All other
             content lives inside this view so the slide-in animation
             is a single translateX on the panel. -->
        <LinearLayout
            android:id="@+id/guide_panel"
            android:layout_width="460dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:orientation="vertical"
            android:background="@drawable/guide_panel_bg"
            android:elevation="24dp"
            android:paddingTop="36dp"
            android:paddingBottom="36dp">

            <!-- Header strip: eyebrow + title + categories pill -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIVE TV"
                    android:textColor="#5DC8FF"
                    android:textSize="11sp"
                    android:letterSpacing="0.36"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/guide_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Channel guide"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.025" />
                <TextView
                    android:id="@+id/guide_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#9DA5B5"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.06" />

                <!-- Category pill rail — horizontal scroll, plays
                     the role of "All channels" / "Sports" / "Movies"
                     filter without taking up vertical space. -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:scrollbars="none"
                    android:overScrollMode="never">
                    <LinearLayout
                        android:id="@+id/guide_category_pills"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>

            <!-- 1dp neon-cyan accent line under the header -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginStart="28dp"
                android:layout_marginEnd="28dp"
                android:background="#1F5DC8FF" />

            <!-- Channel list takes the remaining height -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/guide_channels"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="40dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:scrollbars="none" />

                <!-- Empty state -->
                <TextView
                    android:id="@+id/guide_empty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="Channel list not loaded yet.\nGo back and open Live TV first."
                    android:textColor="#9DA5B5"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Subtle bottom hint bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="12dp"
                android:gravity="center_vertical">
                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/guide_dot_live" />
                <TextView
                    android:id="@+id/guide_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="OK · TUNE     BACK · CLOSE"
                    android:textColor="#6B7587"
                    android:textSize="10sp"
                    android:letterSpacing="0.22"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- RIGHT: floating programme detail card.  Sits in the
             bottom-right corner over the video.  Slides in 200ms
             after the panel; refreshes its content as the user
             D-pads through the channel list. -->
        <FrameLayout
            android:id="@+id/guide_detail"
            android:layout_width="380dp"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="36dp"
            android:layout_marginBottom="36dp"
            android:alpha="0"
            android:background="@drawable/guide_detail_bg"
            android:elevation="18dp">

            <!-- Backdrop poster — programme art or channel logo,
                 with a dark gradient over the bottom so the text
                 is readable.  16:9 aspect. -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/detail_backdrop"
                    android:layout_width="match_parent"
                    android:layout_height="214dp"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"
                    android:contentDescription="@null" />
                <View
                    android:layout_width="match_parent"
                    android:layout_height="214dp"
                    android:background="@drawable/guide_detail_gradient" />

                <!-- Top-left LIVE pill + channel name -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="14dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/guide_live_pill"
                    android:paddingStart="10dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">
                    <View
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@drawable/guide_dot_white"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIVE NOW"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:letterSpacing="0.24" />
                </LinearLayout>

                <!-- Top-right channel logo on glass plate -->
                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="14dp"
                    android:background="@drawable/guide_detail_logo_bg">
                    <ImageView
                        android:id="@+id/detail_channel_logo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_margin="6dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="@null" />
                </FrameLayout>
            </FrameLayout>

            <!-- Programme info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="22dp">

                <TextView
                    android:id="@+id/detail_channel_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#5DC8FF"
                    android:textSize="11sp"
                    android:letterSpacing="0.28"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/detail_programme_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.015"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/detail_time_range"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="#9DA5B5"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.08" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="10dp"
                    android:background="#1FFFFFFF">
                    <View
                        android:id="@+id/detail_progress"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="#5DC8FF" />
                </FrameLayout>

                <TextView
                    android:id="@+id/detail_next"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="#7d8493"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.06"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
