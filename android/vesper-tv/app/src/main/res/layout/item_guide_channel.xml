<?xml version="1.0" encoding="utf-8"?>
<!--
  Channel row for the redesigned (v2.6.2) Live Guide overlay.

  Premium aesthetic:
    [LOGO 56×56 glass plate]  [name + Now/Next + progress  ]
                                                       (channel#)

  The row's background is a `data-focused`-driven selector:
   • Default → transparent
   • Focused → glass card with cyan-accented border + slight scale
  This lets the user "feel" their D-pad movement instead of just
  staring at static rows.

  Used by LiveGuideController.kt's ChannelAdapter (v2.6.2).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/row_root"
    android:layout_width="match_parent"
    android:layout_height="78dp"
    android:layout_marginBottom="6dp"
    android:background="@drawable/guide_channel_row_bg"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingEnd="14dp">

    <!-- Logo -->
    <FrameLayout
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@drawable/guide_logo_bg">
        <ImageView
            android:id="@+id/row_logo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="6dp"
            android:scaleType="fitCenter"
            android:contentDescription="@null" />
    </FrameLayout>

    <!-- Centre column: name + Now/Next + progress -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/row_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:letterSpacing="-0.005" />

        <TextView
            android:id="@+id/row_now"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="#C7CFDB"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Progress bar — driven from code -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="5dp"
            android:background="#1AFFFFFF">
            <View
                android:id="@+id/row_progress"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="#5DC8FF" />
        </FrameLayout>
    </LinearLayout>

    <!-- Right column: channel number + ON NOW pill (shown when this
         row is the currently-playing channel). -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end|center_vertical"
        android:layout_marginStart="10dp">
        <TextView
            android:id="@+id/row_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#6B7587"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:letterSpacing="0.08" />
        <TextView
            android:id="@+id/row_playing_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/guide_playing_pill"
            android:text="ON"
            android:textColor="#5DC8FF"
            android:textSize="9sp"
            android:letterSpacing="0.2"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
