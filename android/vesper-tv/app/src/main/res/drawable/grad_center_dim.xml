<?xml version="1.0" encoding="utf-8"?>
<!--
  Soft radial darkening behind the centre play/skip buttons.  The
  controls_root already has a flat 40% scrim under everything; this
  adds an extra ~25% in the middle band where bright scenes (skies,
  white scenes) tend to wash the icons out.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="radial"
        android:gradientRadius="500dp"
        android:centerX="0.5"
        android:centerY="0.5"
        android:startColor="#66000000"
        android:endColor="#00000000" />
</shape>
