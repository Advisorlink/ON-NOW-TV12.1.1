<?xml version="1.0" encoding="utf-8"?>
<!--
  Vesper exit-confirm card background:
  - Inky near-black with a subtle blue undertone (matches the
    rest of the app's `--vesper-bg-1` token)
  - Slight 1px neon-blue border for the glass-edge highlight
  - Generous corner radius so it reads as a sheet, not a popup
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#0F1626"
        android:endColor="#080C16" />
    <corners android:radius="28dp" />
    <stroke
        android:width="1dp"
        android:color="#335DC8FF" />
</shape>
