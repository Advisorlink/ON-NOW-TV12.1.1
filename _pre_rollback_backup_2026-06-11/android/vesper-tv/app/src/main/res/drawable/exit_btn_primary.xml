<?xml version="1.0" encoding="utf-8"?>
<!--
  v2.10.7 — Close App (destructive).
  Default state: outlined ghost (identical to Stay so neither
  looks "pre-selected").  Focused: SOLID red danger fill — clearly
  distinguishable from Stay's blue focus glow, so the user can
  never accidentally hit Close thinking it's Stay.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#E5484D" />
            <corners android:radius="999dp" />
            <stroke android:width="2dp" android:color="#FFFFFF" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#C8383D" />
            <corners android:radius="999dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0DFFFFFF" />
            <corners android:radius="999dp" />
            <stroke android:width="1dp" android:color="#26FFFFFF" />
        </shape>
    </item>
</selector>
