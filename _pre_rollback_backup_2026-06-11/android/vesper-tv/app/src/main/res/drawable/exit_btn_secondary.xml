<?xml version="1.0" encoding="utf-8"?>
<!--
  v2.10.7 — Stay (safe default).
  Default state: outlined ghost so it reads as inactive at a glance.
  Focused: SOLID neon-blue fill so it's immediately obvious this is
  the selected action (matches the brand colour everywhere else).
  Stay is the safer choice → blue is the "safe" colour.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#5DC8FF" />
            <corners android:radius="999dp" />
            <stroke android:width="2dp" android:color="#FFFFFF" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#4BBDF5" />
            <corners android:radius="999dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0DFFFFFF" />
            <corners android:radius="999dp" />
            <stroke android:width="1dp" android:color="#26FFFFFF" />
        </shape>
    </item>
</selector>
