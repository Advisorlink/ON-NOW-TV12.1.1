<?xml version="1.0" encoding="utf-8"?>
<!-- v2.10.8 — Next-episode countdown progress bar.  Cyan fill on a
     dark unfilled track.  Used by the auto-advance card that
     appears in the last 15 s of a TV episode. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <corners android:radius="2dp" />
            <solid android:color="#1F2A40" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="2dp" />
                <solid android:color="#5DC8FF" />
            </shape>
        </clip>
    </item>
</layer-list>
