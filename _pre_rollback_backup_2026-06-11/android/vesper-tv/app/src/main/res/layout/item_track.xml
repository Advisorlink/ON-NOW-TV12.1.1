<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/track_row"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:focusable="true"
    android:clickable="true"
    android:background="@drawable/track_row_bg"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:layout_marginBottom="6dp">

    <View
        android:id="@+id/track_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/track_dot_off" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/track_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/track_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#7E8A9C"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
