<?xml version="1.0" encoding="utf-8"?>
<!-- v0.5 — Bottom-of-screen darkening gradient.  Sits between the
     wallpaper and the dock so the dock label text + tile imagery
     always reads cleanly on any wallpaper. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="90"
        android:startColor="#E6000814"
        android:centerColor="#80000814"
        android:endColor="#00000814" />
</shape>
