<?xml version="1.0" encoding="utf-8"?>
<!-- Inset input field shown inside the brand-styled dialogs.  Deep
     navy fill with a thin border that glows neon blue on focus. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#0E1422" />
            <stroke android:width="1.5dp" android:color="#5DC8FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#0E1422" />
            <stroke android:width="1dp" android:color="#1E2A44" />
        </shape>
    </item>
</selector>
