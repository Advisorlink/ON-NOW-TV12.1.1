<?xml version="1.0" encoding="utf-8"?>
<!-- Sport-picker pill background.
     focused / activated → cyan filled + glow
     resting → glass-morphism navy with cyan outline -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#5DC8FF" />
            <corners android:radius="999dp" />
            <stroke android:width="2dp" android:color="#7DDDFF" />
        </shape>
    </item>
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="#26486B" />
            <corners android:radius="999dp" />
            <stroke android:width="2dp" android:color="#5DC8FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1F273A" />
            <corners android:radius="999dp" />
            <stroke android:width="1dp" android:color="#1F2E4A" />
        </shape>
    </item>
</selector>
