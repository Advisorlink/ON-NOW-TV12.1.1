<?xml version="1.0" encoding="utf-8"?>
<!-- v2.9.7 LoginActivity glass card.
     Subtle vertical gradient with a 1 px neon-blue top border that
     anchors the V2 LIVE TV branding. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:angle="270"
                android:startColor="#1E2A44"
                android:endColor="#101728" />
            <stroke android:width="1dp" android:color="#26344E" />
        </shape>
    </item>
    <!-- Neon-blue top accent bar -->
    <item
        android:top="0dp"
        android:left="0dp"
        android:right="0dp"
        android:height="3dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="22dp"
                android:topRightRadius="22dp" />
            <gradient
                android:angle="0"
                android:startColor="#5DC8FF"
                android:centerColor="#3A95FF"
                android:endColor="#5DC8FF" />
        </shape>
    </item>
</layer-list>
