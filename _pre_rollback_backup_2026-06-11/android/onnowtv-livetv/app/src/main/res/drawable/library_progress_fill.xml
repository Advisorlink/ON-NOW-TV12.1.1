<?xml version="1.0" encoding="utf-8"?>
<!-- Filled portion of the dialog progress indicator — cyan/blue
     gradient that reads as "active" against the dark dialog body. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="3dp" />
    <gradient
        android:angle="0"
        android:startColor="#3B82F6"
        android:endColor="#5C9CFF" />
</shape>
