<?xml version="1.0" encoding="utf-8"?>
<!--
    LibraryActivity — full-screen "My Library" hub.

    Layout (top → bottom):
      • compact header with clock + section title
      • COLLECTIONS row (16:9 AI-cover tiles, horizontal scroll)
      • FAVOURITES row (channel tiles w/ NOW programme, horizontal scroll)

    Each row has its own RecyclerView so the user can flick UP/DOWN
    between the two sections with the d-pad.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/livetv_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="22dp"
        android:paddingBottom="20dp">

        <!-- ─── Top strip: title + clock ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="36dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="@color/livetv_accent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.32"
                    android:text="LIVE TV" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/livetv_fg"
                    android:textSize="38sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.03"
                    android:text="MY LIBRARY" />
            </LinearLayout>

            <TextView
                android:id="@+id/lib_clock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/livetv_fg_bright"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ─── COLLECTIONS section ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="36dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/livetv_fg_dim"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.30"
                android:text="COLLECTIONS" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="#1F2A45" />

            <TextView
                android:id="@+id/lib_collections_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/livetv_fg_dim"
                android:textSize="10sp"
                android:text="0" />

            <!-- v2.9.1: header-mounted "+ Add Collection" button.
                 Replaces the virtual tile that used to sit at the
                 front of the Collections row. -->
            <TextView
                android:id="@+id/lib_add_collection_btn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="14dp"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="+ ADD COLLECTION"
                android:textColor="#5DC8FF"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:letterSpacing="0.22"
                android:background="@drawable/library_add_btn_bg"
                android:focusable="true"
                android:clickable="true" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lib_collections_list"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:paddingStart="36dp"
                android:paddingEnd="36dp"
                android:clipToPadding="false"
                android:descendantFocusability="afterDescendants"
                android:focusable="false"
                android:orientation="horizontal" />

            <TextView
                android:id="@+id/lib_collections_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="monospace"
                android:textColor="@color/livetv_fg_dim"
                android:textSize="12sp"
                android:letterSpacing="0.22"
                android:text="TAP &quot;+ ADD COLLECTION&quot; TO START — OR LONG-PRESS A CHANNEL"
                android:visibility="gone" />
        </FrameLayout>

        <!-- ─── FAVOURITES section ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="36dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/livetv_fg_dim"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.30"
                android:text="FAVOURITES" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="#1F2A45" />

            <TextView
                android:id="@+id/lib_favourites_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/livetv_fg_dim"
                android:textSize="10sp"
                android:text="0" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lib_favourites_list"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:paddingStart="36dp"
                android:paddingEnd="36dp"
                android:clipToPadding="false"
                android:descendantFocusability="afterDescendants"
                android:focusable="false"
                android:orientation="horizontal" />

            <TextView
                android:id="@+id/lib_favourites_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="monospace"
                android:textColor="@color/livetv_fg_dim"
                android:textSize="12sp"
                android:letterSpacing="0.22"
                android:text="LONG-PRESS A CHANNEL TO ADD ONE HERE"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <!-- Bottom hint strip -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="32dp"
        android:fontFamily="monospace"
        android:textColor="@color/livetv_fg_dim"
        android:textSize="10sp"
        android:letterSpacing="0.20"
        android:text="OK = OPEN  ·  LONG-PRESS = REGENERATE COVER  ·  BACK = EXIT" />
</FrameLayout>
