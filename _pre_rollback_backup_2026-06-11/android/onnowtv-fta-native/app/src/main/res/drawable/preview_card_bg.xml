<?xml version="1.0" encoding="utf-8"?>
<!-- Cinematic backdrop frame for the sidebar preview/info card.
     Black canvas with soft cyan rim glow so the artwork pops.  -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#000000" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#2A5DC8FF" />
        </shape>
    </item>
</layer-list>
