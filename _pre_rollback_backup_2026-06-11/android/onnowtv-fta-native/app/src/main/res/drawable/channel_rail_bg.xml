<?xml version="1.0" encoding="utf-8"?>
<!-- Channel rail.  Activated state = the channel is favourited
     (long-press OK on any of its programme cells).  Renders a soft
     cyan glow stroke. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="#162033" />
            <corners android:radius="10dp" />
            <stroke android:width="2dp" android:color="@color/fta_blue" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0E1422" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="@color/fta_line" />
        </shape>
    </item>
</selector>
