<?xml version="1.0" encoding="utf-8"?>
<!-- "Coming up next" card.  Subtle off-black surface with a cyan
     top accent strip to balance the eyebrow label. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF101728"
                android:centerColor="#FF0B1322"
                android:endColor="#FF080C18"
                android:angle="270" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#1A5DC8FF" />
        </shape>
    </item>
    <item android:height="2dp" android:gravity="top">
        <shape android:shape="rectangle">
            <solid android:color="@color/fta_blue" />
        </shape>
    </item>
</layer-list>
