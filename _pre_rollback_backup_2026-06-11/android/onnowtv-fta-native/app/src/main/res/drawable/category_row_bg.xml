<?xml version="1.0" encoding="utf-8"?>
<!-- Category submenu row.  Focused row gets a cyan left bar + tint. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#1A2438" />
                </shape>
            </item>
            <item android:width="3dp" android:gravity="start">
                <shape android:shape="rectangle">
                    <solid android:color="@color/fta_blue" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_activated="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#10182B" />
                </shape>
            </item>
            <item android:width="3dp" android:gravity="start">
                <shape android:shape="rectangle">
                    <solid android:color="@color/fta_blue_bright" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
