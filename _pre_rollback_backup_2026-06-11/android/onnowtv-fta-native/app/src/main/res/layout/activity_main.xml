<?xml version="1.0" encoding="utf-8"?>
<!--
    Splash screen — held for ~900 ms while EpgActivity warms.
    Layout mirrors the WebView FTA splash: "V2" red wordmark next
    to "Free-to-Air" white wordmark, centred on the warm gradient.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fta_splash_gradient">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="V2"
            android:textColor="#FFFFFF"
            android:textSize="140sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.04"
            android:shadowColor="#88FF2535"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="32" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Free-to-Air"
            android:textColor="#FFFFFF"
            android:textSize="64sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.01"
            android:shadowColor="#66000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="8" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="40dp"
        android:text="LOADING FREE-TO-AIR · 187 CHANNELS"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:letterSpacing="0.22"
        android:alpha="0.85" />
</FrameLayout>
